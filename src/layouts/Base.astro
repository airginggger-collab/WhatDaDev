---
import "../styles/global.css";
const { title = "WhatDaDev — внедрение ELMA365 и готовый ЭДО из коробки", description = "Внедрение ELMA365 под ключ и коробочные продукты для документооборота. РФ и КЗ.", jsonld = [] } = Astro.props;
const org = {
  "@context": "https://schema.org", "@type": "Organization",
  name: "WhatDaDev", url: "https://whatdadev.ru",
  description: "Внедрение ELMA365 под ключ и готовые продукты для документооборота. РФ и КЗ.",
  email: "sales@whatdadev.ru", telephone: "+7-980-471-57-72",
  areaServed: ["RU", "KZ"], sameAs: ["https://t.me/WhatDaDev"],
};
const website = { "@context": "https://schema.org", "@type": "WebSite", name: "WhatDaDev", url: "https://whatdadev.ru", inLanguage: ["ru", "en"] };
const blocks = [org, website, ...jsonld];
---
<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap&subset=cyrillic" rel="stylesheet" />
    {blocks.map((b) => <script type="application/ld+json" set:html={JSON.stringify(b)} />)}
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a class="logo" href="/">What<b>Da</b>Dev</a>
        <button class="nav-toggle" id="navToggle" aria-label="Открыть меню" aria-expanded="false" aria-controls="nav">☰</button>
        <nav class="nav" id="nav">
          <a href="/products/express/">Продукты</a>
          <a href="/services/">Услуги</a>
          <a href="/industries/">Отрасли</a>
          <a href="/elma365/">ELMA365</a>
          <a href="/press/">Пресс-центр</a>
          <a href="/contacts/">Контакты</a>
          <a class="btn" href="/contacts/">Записаться на демо</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container footer-grid">
        <div>
          <div class="logo" style="color:#fff;margin-bottom:8px">What<b>Da</b>Dev</div>
          <p>Внедрение ELMA365 и готовые продукты для документооборота. РФ и КЗ.</p>
        </div>
        <div>
          <p><b style="color:#fff">Контакты</b></p>
          <p>Telegram: @WhatDaDev<br/>WhatsApp: +7 980 471-57-72<br/>sales@whatdadev.ru</p>
        </div>
        <div>
          <p><b style="color:#fff">Разделы</b></p>
          <p><a href="/products/express/">Экспресс внедрение</a><br/><a href="/services/vnedrenie/">Внедрение</a><br/><a href="/industries/">Отрасли</a><br/><a href="/elma365/">ELMA365</a><br/><a href="/contacts/">Контакты</a></p>
        </div>
      </div>
      <div class="container" style="margin-top:24px;opacity:.6">© 2026 WhatDaDev · прототип</div>
    </footer>
    <script>
      const t = document.getElementById('navToggle');
      const n = document.getElementById('nav');
      t && t.addEventListener('click', () => {
        const open = n.classList.toggle('open');
        t.setAttribute('aria-expanded', String(open));
      });
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (!e.isIntersecting) continue;
          e.target.classList.add('in');
          if (e.target.dataset.p) {
            const fg = e.target.querySelector('.fg');
            if (fg) fg.style.setProperty('--p', e.target.dataset.p);
          }
          io.unobserve(e.target);
        }
      }, { threshold: 0.2 });
      document.querySelectorAll('.reveal, [data-p]').forEach((el) => io.observe(el));
    </script>
  </body>
</html>
