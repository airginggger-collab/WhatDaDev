---
import "@fontsource-variable/golos-text";
import "@fontsource-variable/piazzolla";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/500.css";
import "../styles/global.css";
import contacts from "../data/contacts.json";
import { jsonLd } from "../lib/jsonld.ts";
const { title = "WhatDaDev: внедрение ELMA365 и готовый ЭДО из коробки", description = "Внедрение ELMA365 под ключ и коробочные продукты для документооборота. РФ и КЗ.", jsonld = [], noindex = false } = Astro.props;
const org = {
  "@context": "https://schema.org", "@type": "Organization",
  name: "WhatDaDev", url: "https://whatdadev.ru",
  description: "Внедрение ELMA365 под ключ и готовые продукты для документооборота. РФ и КЗ.",
  email: contacts.email, telephone: contacts.phone,
  areaServed: ["RU", "KZ"], sameAs: [`https://t.me/${contacts.telegram}`],
};
const website = { "@context": "https://schema.org", "@type": "WebSite", name: "WhatDaDev", url: "https://whatdadev.ru", inLanguage: ["ru", "en"] };
const blocks = [org, website, ...jsonld];
const currentPath = Astro.url.pathname;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL("/og.png", Astro.site).href;
---
<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#10151A" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="WhatDaDev" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script is:inline>document.documentElement.classList.add('js');</script>
    {blocks.map((b) => <script type="application/ld+json" set:html={jsonLd(b)} />)}
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a class="logo" href="/" aria-label="WhatDaDev, главная">
          <svg width="54" height="34" viewBox="0 0 54 34" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- W -->
            <path d="M0 0 L6 0 L13 22 L19 9 L26 22 L32 0 L38 0 L28 34 L19 17 L10 34 Z" fill="currentColor"/>
            <!-- D: solid rectangle + tight half-ellipse right side -->
            <rect x="35" y="0" width="7" height="34" fill="currentColor"/>
            <ellipse cx="42" cy="17" rx="12" ry="17" fill="currentColor"/>
            <!-- D inner cutout: tight half-ellipse -->
            <ellipse cx="43" cy="17" rx="7" ry="11" fill="var(--dark-bg,#10151A)"/>
            <rect x="35" y="6" width="8" height="22" fill="var(--dark-bg,#10151A)"/>
          </svg>
        </a>
        <button class="nav-toggle" id="navToggle" aria-label="Открыть меню" aria-expanded="false" aria-controls="nav">☰</button>
        <nav class="nav" id="nav">
          <a href="/products/express/" aria-current={currentPath.startsWith('/products/') ? 'page' : undefined}>Продукты</a>
          <a class="nav-highlight" href="/coordo/" aria-current={currentPath === '/coordo/' ? 'page' : undefined}>Coordo</a>
          <a href="/services/" aria-current={currentPath.startsWith('/services/') ? 'page' : undefined}>Услуги</a>
          <a href="/industries/" aria-current={currentPath.startsWith('/industries/') ? 'page' : undefined}>Отрасли</a>
          <a href="/press/" aria-current={currentPath.startsWith('/press/') ? 'page' : undefined}>Пресс-центр</a>
          <a href="/company/about/" aria-current={currentPath.startsWith('/company/') ? 'page' : undefined}>О команде</a>
          <a href="/contacts/" aria-current={currentPath === '/contacts/' ? 'page' : undefined}>Контакты</a>
          <a class="btn" href="/contacts/">Записаться на демо</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container footer-grid">
        <div class="footer-brand">
          <div class="logo" style="color:var(--dark-text);margin-bottom:10px">What<b>Da</b>Dev</div>
          <p style="max-width:220px">Внедрение ELMA365 и готовые продукты для документооборота. РФ и КЗ.</p>
          <div style="margin-top:16px;font-size:13px">
            <p>Telegram: @{contacts.telegram}</p>
            <p>WhatsApp: {contacts.phone}</p>
            <p><a href={`mailto:${contacts.email}`}>{contacts.email}</a></p>
          </div>
        </div>
        <div>
          <p class="footer-heading">Продукты</p>
          <nav aria-label="Продукты">
            <a href="/products/express/">Экспресс внедрение</a>
            <a href="/coordo/">Coordo: ЭДО из коробки</a>
            <a href="/products/express/pricing/">Цены</a>
            <a href="/products/modules/">Модули</a>
            <a href="/products/express/vs-razrabotka/">Vs разработка</a>
          </nav>
        </div>
        <div>
          <p class="footer-heading">Услуги</p>
          <nav aria-label="Услуги">
            <a href="/services/">Все услуги</a>
            <a href="/services/vnedrenie/">Внедрение ELMA365</a>
            <a href="/services/razrabotka/">Разработка</a>
            <a href="/industries/">Отрасли</a>
          </nav>
        </div>
        <div>
          <p class="footer-heading">Компания</p>
          <nav aria-label="Компания">
            <a href="/company/about/">О команде</a>
            <a href="/elma365/">ELMA365</a>
            <a href="/contacts/">Контакты</a>
          </nav>
          <p class="footer-heading" style="margin-top:20px">Пресс-центр</p>
          <nav aria-label="Пресс-центр">
            <a href="/press/">Все статьи</a>
            <a href="/press/glossary/">Глоссарий ЭДО</a>
          </nav>
        </div>
      </div>
      <div class="container footer-bottom">
        <span>© 2026 WhatDaDev</span>
        <span>Внедрение ELMA365 в России и Казахстане</span>
      </div>
    </footer>
    <button id="backToTop" class="back-to-top" aria-label="Наверх">↑</button>
    <script>
      const t = document.getElementById('navToggle');
      const n = document.getElementById('nav');
      t && t.addEventListener('click', () => {
        const open = n.classList.toggle('open');
        t.setAttribute('aria-expanded', String(open));
      });
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (!e.isIntersecting) continue;
          e.target.classList.add('in');
          if (e.target.dataset.p) {
            const fg = e.target.querySelector('.fg');
            if (fg) fg.style.setProperty('--p', e.target.dataset.p);
          }
          io.unobserve(e.target);
        }
      }, { threshold: 0.2 });
      document.querySelectorAll('.reveal, [data-p]').forEach((el) => io.observe(el));
      const btt = document.getElementById('backToTop');
      if (btt) {
        window.addEventListener('scroll', () => {
          const show = window.scrollY > 400;
          btt.style.opacity = show ? '1' : '0';
          btt.style.pointerEvents = show ? 'auto' : 'none';
        }, { passive: true });
        btt.addEventListener('click', () => {
          const prefersReduced = window.matchMedia('(prefers-reduced-motion:reduce)').matches;
          window.scrollTo({ top: 0, behavior: prefersReduced ? 'auto' : 'smooth' });
        });
      }
      document.querySelectorAll('.faq-q').forEach(btn => {
        btn.addEventListener('click', () => {
          const expanded = btn.getAttribute('aria-expanded') === 'true';
          btn.setAttribute('aria-expanded', String(!expanded));
          btn.nextElementSibling.classList.toggle('open', !expanded);
        });
      });
    </script>
  </body>
</html>
