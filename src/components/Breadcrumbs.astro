---
import { jsonLd } from "../lib/jsonld.ts";
const { items } = Astro.props;
const site = "https://whatdadev.ru";
// Условие вывода item совпадает с условием ссылки в разметке ниже: текущая
// страница (последний пункт) остаётся без item, даже если href ей передали.
// Раньше правила расходились, и разметка могла обещать ссылку, которой нет.
const isLink = (it, i) => Boolean(it.href) && i < items.length - 1;
const ld = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: items.map((it, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: it.name,
    ...(isLink(it, i) ? { item: site + it.href } : {}),
  })),
};
---
<nav class="crumbs" aria-label="Хлебные крошки">
  {items.map((it, i) => (
    <>
      {i > 0 && <span class="sep">/</span>}
      {isLink(it, i) ? <a href={it.href}>{it.name}</a> : <span aria-current="page">{it.name}</span>}
    </>
  ))}
</nav>
<script type="application/ld+json" set:html={jsonLd(ld)} />
