---
const { items } = Astro.props;
const site = "https://whatdadev.ru";
const ld = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: items.map((it, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: it.name,
    ...(it.href ? { item: site + it.href } : {}),
  })),
};
---
<nav class="crumbs" aria-label="Хлебные крошки">
  {items.map((it, i) => (
    <>
      {i > 0 && <span class="sep">/</span>}
      {it.href && i < items.length - 1 ? <a href={it.href}>{it.name}</a> : <span aria-current="page">{it.name}</span>}
    </>
  ))}
</nav>
<script type="application/ld+json" set:html={JSON.stringify(ld)} />
