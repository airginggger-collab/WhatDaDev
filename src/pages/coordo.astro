  .coordo-list.good li::before { content:"✓"; position:absolute; left:0; color:#4ade80; font-weight:700; }
  .coordo-list.bad li::before { content:"✗"; position:absolute; left:0; color:#f87171; font-weight:700; }

  /* roadmap */
  .roadmap { display:grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap:20px; }
  .rm-item { background:var(--bg-card,#fff); border:1px solid var(--border); border-radius:var(--radius); padding:20px; position:relative; }
  .rm-item.current { border-color:var(--accent); }
  .rm-tag { font-size:11px; font-weight:600; color:var(--muted); text-transform:uppercase; letter-spacing:.5px; margin-bottom:8px; }
  .rm-tag-current { color:var(--accent); }
  .rm-ver { font-size:20px; font-weight:700; color:var(--accent); }
  .rm-date { font-size:12px; color:var(--muted); margin-bottom:8px; }
  .rm-item h3 { font-size:15px; margin-bottom:6px; }
  .rm-item p { font-size:13px; color:var(--muted); line-height:1.5; }

  /* currency tabs */
  .currency-tabs { display:flex; gap:8px; flex-wrap:wrap; }
  .cur-tab { background:transparent; border:1px solid var(--border); border-radius:6px; padding:6px 14px; font-size:14px; cursor:pointer; transition:.2s; color:var(--text); }
  .cur-tab.active { background:var(--accent); color:#fff; border-color:var(--accent); }
  .price-old { font-size:1rem; color:var(--muted); text-decoration:line-through; display:inline-block; }

  /* voice card */
  .voice-card {
    background: var(--dark-bg, #191D1B);
    border-radius: var(--radius);
    padding: 32px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
  }
</style>

<script>
  // currency switcher
  const tabs = document.querySelectorAll('.cur-tab');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      const cur = tab.dataset.cur;
      document.querySelectorAll('.price-val').forEach(el => {
        el.style.display = el.classList.contains('price-val-' + cur) ? '' : 'none';
      });
    });
  });
  // init: show rub only
  document.querySelectorAll('.price-val-kzt, .price-val-usd, .price-val-eur').forEach(el => el.style.display = 'none');
</script>
