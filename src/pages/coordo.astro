---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
const title = "Coordo — согласование документов и рабочих процессов без разработки с нуля | WhatDaDev";
const description = "Универсальный инструмент настройки маршрутов согласования и три готовых контура для старта в первый день. Договоры, ОРД, корреспонденция + замещения на ELMA365.";
const jsonld = [
  {
    "@context": "https://schema.org", "@type": "SoftwareApplication",
    name: "Coordo — Экспресс внедрение ЭДО",
    applicationCategory: "BusinessApplication",
    operatingSystem: "ELMA365",
    url: "https://whatdadev.ru/coordo/",
    description: "Готовые контуры согласования документов на ELMA365. Без разработки с нуля.",
    offers: { "@type": "Offer", price: "690000", priceCurrency: "RUB", availability: "https://schema.org/InStock" },
    provider: { "@type": "Organization", name: "WhatDaDev", url: "https://whatdadev.ru" },
  },
];
---
<Base title={title} description={description} jsonld={jsonld}>

  <!-- HERO -->
  <section class="hero" style="min-height:auto;padding:0">
    <div class="container" style="padding-top:72px;padding-bottom:56px;width:100%">
      <Breadcrumbs items={[{ name: "Главная", href: "/" }, { name: "Coordo" }]} />
      <div class="eyebrow reveal" style="color:#9CC4B0;margin-top:16px">Экосистема на базе ELMA365 — by WhatDaDev</div>
      <h1 class="reveal" style="transition-delay:60ms;max-width:840px;font-size:clamp(28px,4.2vw,52px)">
        Coordo — согласование документов и рабочих процессов<br>без разработки с нуля
      </h1>
      <p class="lead reveal" style="transition-delay:120ms;max-width:640px">
        Универсальный инструмент настройки маршрутов согласования и три готовых контура для старта в первый день. Экосистема, которая растёт вместе с вашим бизнесом.
      </p>
      <div class="btn-row reveal" style="transition-delay:180ms">
        <a class="btn" href="/contacts/">Записаться на демонстрацию</a>
        <a class="btn-secondary" href="/products/express/">Подробнее о продукте</a>
      </div>
      <!-- trust stats -->
      <div class="coordo-stats reveal" style="transition-delay:260ms">
        <div class="cstat"><span class="cstat-n">3</span><span class="cstat-l">готовых контура из коробки</span></div>
        <div class="cstat"><span class="cstat-n">6</span><span class="cstat-l">мес. техническая поддержка</span></div>
        <div class="cstat"><span class="cstat-n">×5</span><span class="cstat-l">быстрее процессы согласования</span></div>
        <div class="cstat"><span class="cstat-n">8+</span><span class="cstat-l">модулей в экосистеме к концу 2026</span></div>
      </div>
    </div>
  </section>

  <!-- PROMO PRICING BAR -->
  <section style="background:var(--accent);padding:18px 0">
    <div class="container" style="display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap">
      <div style="color:#fff">
        <strong>Акция до 31 июля 2026</strong> — специальная цена на полную экосистему
      </div>
      <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
        <span style="color:rgba(255,255,255,.6);text-decoration:line-through;font-size:1.1rem">990 000 ₽</span>
        <span style="color:#fff;font-size:1.4rem;font-weight:700">690 000 ₽</span>
        <a class="btn" href="/contacts/" style="background:#fff;color:var(--accent);border-color:#fff">Записаться на демо</a>
      </div>
    </div>
  </section>

  <!-- VIDEO DEMO -->
  <section style="background:var(--dark-bg);padding:56px 0 72px">
    <div class="container reveal" style="max-width:1000px;width:100%">
      <div class="video-card" style="aspect-ratio:16/9">
        <div class="video-card-chrome">
          <span class="url">elma365 · согласование договора · запись экрана</span>
        </div>
        <video
          src="/video/coordo-demo.mp4"
          autoplay muted loop playsinline preload="none"
          style="width:100%;height:100%;object-fit:cover;display:block;padding-top:32px"
        ></video>
      </div>
      <p style="text-align:center;font-size:13px;color:var(--dark-muted);margin-top:14px">
        Запись реального процесса согласования договора в Coordo
      </p>
    </div>
  </section>

  <!-- ЧТО ВХОДИТ В ПОСТАВКУ -->
  <section class="section">
    <div class="container">
      <div class="eyebrow reveal">Что входит в поставку</div>
      <h2 class="reveal">Бизнес-разделы экосистемы</h2>
      <p class="lead reveal">В первый день у вас работают четыре готовых раздела. Остальные появятся по мере выхода новых версий. Каждый раздел опционален — берёте только то, что нужно.</p>
      <div class="grid grid-2" style="margin-top:32px;gap:20px">
        <div class="card reveal">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px">
            <h3>Договоры</h3>
            <span class="badge-ok">v1.0</span>
          </div>
          <p>Полный цикл договора: от инициации и согласования до подписания и архивирования. Поддержка допсоглашений с привязкой к родительскому договору.</p>
          <a href="/products/express/dogovory/" style="font-size:14px;color:var(--accent)">Подробнее →</a>
        </div>
        <div class="card reveal" style="transition-delay:60ms">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px">
            <h3>ОРД — приказы и распоряжения</h3>
            <span class="badge-ok">v1.0</span>
          </div>
          <p>Организационно-распорядительные документы с настраиваемыми маршрутами согласования и подписания. Учёт исполнителей и сроков.</p>
          <a href="/products/express/ord/" style="font-size:14px;color:var(--accent)">Подробнее →</a>
        </div>
        <div class="card reveal" style="transition-delay:120ms">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px">
            <h3>Входящая и исходящая корреспонденция</h3>
            <span class="badge-ok">v1.0</span>
          </div>
          <p>Регистрация, маршрутизация и контроль исполнения входящих и исходящих писем. Связка с договорами и поручениями.</p>
          <a href="/products/express/korrespondenciya/" style="font-size:14px;color:var(--accent)">Подробнее →</a>
        </div>
        <div class="card reveal" style="transition-delay:180ms">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px">
            <h3>Замещения</h3>
            <span class="badge-ok">v1.0</span>
          </div>
          <p>Автоматическое перераспределение задач и полномочий при отсутствии сотрудника. Настройте кто и на какой период замещает коллегу — система всё учтёт.</p>
        </div>
        <div class="card reveal" style="transition-delay:240ms;opacity:.8">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px">
            <h3>Заявки</h3>
            <span class="badge-soon">v1.2 · Q3 2026</span>
          </div>
          <p>Заявки в АХО, на командировку, на оплату счетов — через готовое ядро Coordo, без дополнительной разработки.</p>
        </div>
        <div class="card reveal" style="transition-delay:300ms;opacity:.8">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px">
            <h3>Служебные записки</h3>
            <span class="badge-soon">v1.5 · Q4 2026</span>
          </div>
          <p>Универсальный внутренний документ для согласований, не попадающих в другие контуры. Полный цикл от создания до регистрации.</p>
        </div>
        <div class="card reveal" style="transition-delay:360ms;opacity:.8">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px">
            <h3>Доверенности</h3>
            <span class="badge-soon">v1.7 · Q1 2027</span>
          </div>
          <p>Реестр доверенностей с контролем сроков действия и механизмом отзыва. Полный цикл от выдачи до аннулирования.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ДЛЯ КОГО -->
  <section class="section alt">
    <div class="container">
      <div class="eyebrow reveal">Для кого</div>
      <h2 class="reveal">Управление документами и процессами нужно в любом бизнесе</h2>
      <p class="lead reveal">Производство, ритейл, строительство, услуги — договоры, приказы, поручения и ознакомления есть везде. Coordo закрывает этот вопрос быстро и без лишней разработки.</p>

      <div class="grid grid-2" style="margin-top:16px;gap:20px">
        <div class="card alt reveal">
          <h3>Уже выбрали ELMA365</h3>
          <p>Внедряете платформу и хотите сразу получить ЭДО. Не тратите месяцы на разработку согласований с нуля — Coordo устанавливается поверх ELMA365 и даёт готовые контуры согласования в первый же день.</p>
        </div>
        <div class="card alt reveal" style="transition-delay:60ms">
          <h3>Ищете решение для ЭДО</h3>
          <p>Выбираете платформу для перехода на электронный документооборот. Coordo — это готовый аргумент в пользу ELMA365. Вместо долгого проекта с нуля вы получаете рабочее ЭДО сразу после внедрения платформы.</p>
        </div>
      </div>

      <div class="grid grid-3" style="margin-top:20px;gap:20px">
        <div class="card reveal">
          <h3>Несколько типов документов</h3>
          <p>Договоры, приказы, письма — и не хочется писать отдельный бизнес-процесс под каждый объект.</p>
        </div>
        <div class="card reveal" style="transition-delay:60ms">
          <h3>Важен быстрый старт</h3>
          <p>Бизнес не может ждать месяцы разработки. Coordo настраивается под вас и готов к работе в течение нескольких недель.</p>
        </div>
        <div class="card reveal" style="transition-delay:120ms">
          <h3>Есть свои приложения в ELMA365</h3>
          <p>Подключите их к маршрутам Coordo без ограничений — ядро работает с любыми объектами системы.</p>
        </div>
        <div class="card reveal" style="transition-delay:180ms">
          <h3>Планируете расширять ЭДО</h3>
          <p>Сегодня договоры, завтра заявки, потом поручения. Coordo растёт вместе с вашими потребностями.</p>
        </div>
        <div class="card reveal" style="transition-delay:240ms">
          <h3>Нужна предсказуемая стоимость</h3>
          <p>Разовый платёж, без абонентских сборов за пользователей и скрытых доплат за модули.</p>
        </div>
        <div class="card reveal" style="transition-delay:300ms">
          <h3>Хотите управлять маршрутами самостоятельно</h3>
          <p>Администратор заказчика настраивает маршруты, этапы и условия через интерфейс — без разработчиков.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- НА БАЗЕ ELMA365 -->
  <section class="section">
    <div class="container">
      <div class="eyebrow reveal">Платформа</div>
      <h2 class="reveal">Сделано на базе ELMA365 — и это важно</h2>
      <p class="lead reveal">Мы не строили новую платформу с нуля. Мы взяли зрелую систему и добавили то, чего ей не хватало.</p>

      <div class="grid grid-2" style="margin-top:32px;gap:24px">
        <div class="card reveal">
          <div class="eyebrow" style="font-size:12px;margin-bottom:12px">Ещё не работаете с ELMA365</div>
          <h3>Coordo — готовый старт</h3>
          <p style="margin-bottom:12px">Вместо долгой разработки ЭДО с нуля — четыре работающих контура в первый день после установки платформы, а также все последующие по мере выхода новых версий.</p>
          <p style="margin-bottom:12px"><strong>Платформа живёт и развивается.</strong> ELMA365 регулярно выпускает собственные продукты: CRM, Проекты, Закупки, ServiceDesk, КЭДО. Выбирая платформу, вы получаете доступ ко всей этой экосистеме.</p>
          <p style="margin-bottom:12px"><strong>Никакого зоопарка систем.</strong> Все процессы компании живут в ELMA365. Не нужно выстраивать интеграции между разрозненными инструментами.</p>
          <p style="margin-bottom:12px"><strong>Мобильное приложение в комплекте.</strong> Согласовывать документы и решать задачи можно со смартфона — мобильный клиент ELMA365 работает со всеми контурами Coordo.</p>
          <p><strong>Двойная надёжность.</strong> Вы работаете на платформе ELMA365, за которой стоит крупный российский вендор, и с Coordo от WhatDaDev — сертифицированного партнёра ELMA365.</p>
        </div>
        <div class="card alt reveal" style="transition-delay:80ms">
          <div class="eyebrow" style="font-size:12px;margin-bottom:12px">Уже работаете с ELMA365</div>
          <h3>Быстрый старт на готовой базе</h3>
          <p style="margin-bottom:12px"><strong>Устанавливается на любую действующую инсталляцию.</strong> Coordo начинает работать сразу — не нужно ждать окончания внедрения платформы.</p>
          <p style="margin-bottom:12px"><strong>Ваши приложения подключаются сразу.</strong> Уже построенные объекты в ELMA365 подключаются к маршрутам Coordo без ограничений. Добавляете новый объект — настраиваете маршруты без дополнительной разработки.</p>
          <p style="margin-bottom:12px"><strong>Права и орг. структура уже настроены.</strong> Используется встроенная модель прав ELMA365. Ничего перенастраивать не нужно.</p>
          <p><strong>Coordo не заменяет — расширяет.</strong> CRM, Проекты, Закупки, ServiceDesk, КЭДО продолжают работать рядом.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ПРОБЛЕМА / БЫЛО — СТАЛО -->
  <section class="section alt">
    <div class="container">
      <div class="eyebrow reveal">Проблема</div>
      <h2 class="reveal">Почему автоматизация ЭДО в ELMA365 обходилась так дорого?</h2>
      <p class="lead reveal">Классический подход требовал отдельной разработки под каждый объект — договоры, приказы, письма, поручения. Мы это изменили.</p>

      <div class="grid grid-2" style="margin-top:32px;gap:24px">
        <div class="card" style="border-left:3px solid #f87171">
          <h3 style="color:#f87171;margin-bottom:16px">Было раньше</h3>
          <ul class="coordo-list bad">
            <li>Бизнес-процесс разрабатывался под каждый тип документа отдельно — недели работы</li>
            <li>Согласование договора, приказа и письма — три разных БП, три разные задачи</li>
            <li>Любое изменение логики маршрута — доработка в коде или перестройка процесса</li>
            <li>Дублирование: одинаковые этапы (согласование, доработка, подписание) — в каждом БП заново</li>
            <li>Каждый маршрут требовал отдельной схемы в дизайнере БП — при изменении логики нужно было возвращаться и перерисовывать процесс</li>
          </ul>
        </div>
        <div class="card" style="border-left:3px solid #4ade80">
          <h3 style="color:#4ade80;margin-bottom:16px">Теперь с Coordo</h3>
          <ul class="coordo-list good">
            <li>Один инструмент для всех объектов — настроили маршрут, связали с приложением, готово</li>
            <li>Договор, приказ, письмо — маршруты для каждого настраиваются в едином интерфейсе</li>
            <li>Изменить логику маршрута может любой ответственный пользователь через интуитивно понятный интерфейс</li>
            <li>Этапы согласования, подписания и доработки — один раз описаны в ядре, работают везде</li>
            <li>Минимум работы в дизайнере БП — логика маршрутов хранится в настройках ядра, а не разбросана по схемам процессов</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ЯДРО ЭКОСИСТЕМЫ -->
  <section class="section">
    <div class="container">
      <div class="eyebrow reveal">Ядро экосистемы</div>
      <h2 class="reveal">Универсальный движок процессов</h2>
      <p class="lead reveal">Ядро Coordo — это инструмент настройки маршрутов: согласования, подписания, ознакомления и постановки поручений. Для одного объекта можно задать несколько маршрутов в зависимости от условий — значении суммы, типе документа, контрагенте или любом другом поле.</p>

      <div class="grid grid-2" style="margin-top:32px;gap:24px;align-items:start">
        <div>
          <h3 style="margin-bottom:16px">Возможности ядра</h3>
          <ul class="coordo-list good">
            <li>Условный маршрут: разные ветки в зависимости от значений полей</li>
            <li>Делегирование задачи согласования другому исполнителю</li>
            <li>Возможность привлечения дополнительных согласующих</li>
            <li>Отправка на доработку с комментарием и возвратом к инициатору</li>
            <li>Гибкое управление списком исполнителей по этапам</li>
          </ul>
          <p style="margin-top:16px;font-size:14px;color:var(--muted)">Модули подключаются опционально — берёте только нужное, каждый устанавливается отдельно. Ваши приложения ELMA365 подключаются к маршрутам без ограничений, как готовые модули. Минимум работы в дизайнере БП — основная логика маршрутов настраивается через интерфейс.</p>
        </div>
        <div>
          <div class="card alt" style="font-family:monospace;font-size:13px">
            <div style="color:var(--muted);margin-bottom:12px;font-family:inherit">Настройка маршрута ЭДО — демо</div>
            <div style="margin-bottom:8px"><strong>Название:</strong> Маршрут согласования договоров</div>
            <div style="margin-bottom:8px"><strong>Приложение:</strong> Договоры и допсоглашения</div>
            <div style="margin-bottom:12px"><strong>Базовый маршрут:</strong> Да</div>
            <div style="margin-bottom:8px;font-weight:600">Этапы согласования</div>
            <table style="width:100%;border-collapse:collapse;font-size:12px">
              <tr style="color:var(--muted)"><td style="padding:4px 8px 4px 0">№</td><td style="padding:4px 8px 4px 0">Вид</td><td style="padding:4px 8px 4px 0">Должность</td><td style="padding:4px">Срок</td></tr>
              <tr><td style="padding:4px 8px 4px 0">1</td><td style="padding:4px 8px 4px 0">Послед.</td><td style="padding:4px 8px 4px 0">Юридический отдел</td><td style="padding:4px">3 дня</td></tr>
              <tr><td style="padding:4px 8px 4px 0">2</td><td style="padding:4px 8px 4px 0">Послед.</td><td style="padding:4px 8px 4px 0">Финансовый директор</td><td style="padding:4px">2 дня</td></tr>
              <tr><td style="padding:4px 8px 4px 0">3</td><td style="padding:4px 8px 4px 0">Паралл.</td><td style="padding:4px 8px 4px 0">Генеральный директор</td><td style="padding:4px">1 день</td></tr>
            </table>
            <div style="margin-top:12px;font-weight:600;margin-bottom:6px">Условия применения маршрута</div>
            <div style="font-size:12px;color:var(--muted)">Стоимость договора &gt; 100 000 ₽</div>
          </div>

          <div style="margin-top:16px">
            <h3 style="margin-bottom:12px">Модули ядра</h3>
            <div class="grid grid-2" style="gap:12px">
              <div class="card" style="padding:14px">
                <div style="font-size:13px;font-weight:600">Маршруты подписания</div>
                <div style="font-size:12px;color:var(--muted)">Интеграция с Диадок и СБИС</div>
                <span class="badge-soon" style="margin-top:6px;display:inline-block">v1.1</span>
              </div>
              <div class="card" style="padding:14px">
