---
import Base from "../layouts/Base.astro";
const title = "Coordo — согласование документов без разработки с нуля | WhatDaDev";
const description = "Готовые маршруты согласования договоров, ОРД и корреспонденции на ELMA365. Запуск за недели. Посмотрите как это работает.";
const jsonld = [
  {
    "@context": "https://schema.org", "@type": "SoftwareApplication",
    name: "Coordo — Экспресс внедрение ЭДО",
    applicationCategory: "BusinessApplication",
    operatingSystem: "ELMA365",
    url: "https://whatdadev.ru/coordo/",
    description: "Готовые контуры согласования документов на ELMA365. Без разработки с нуля.",
    offers: { "@type": "Offer", price: "690000", priceCurrency: "RUB", availability: "https://schema.org/InStock" },
    provider: { "@type": "Organization", name: "WhatDaDev", url: "https://whatdadev.ru" },
  },
];
---
<Base title={title} description={description} jsonld={jsonld}>

  <!-- HERO -->
  <section class="hero" style="min-height:auto;padding:0">
    <div class="container" style="padding-top:72px;padding-bottom:56px;width:100%">
      <div class="eyebrow reveal" style="color:#a5b4fc">Продукт · Экспресс внедрение (Coordo)</div>
      <h1 class="reveal" style="transition-delay:60ms;max-width:780px;font-size:clamp(30px,4.2vw,52px)">
        Согласование документов —<br>без разработки с нуля
      </h1>
      <p class="lead reveal" style="transition-delay:120ms;max-width:600px">
        Готовые маршруты для договоров, ОРД и корреспонденции на базе ELMA365. Запуск за недели. Один раз, без подписки.
      </p>
      <div class="btn-row reveal" style="transition-delay:180ms">
        <a class="btn" href="/contacts/">Записаться на демо</a>
        <a class="btn-secondary" href="/products/express/">Подробнее о продукте</a>
      </div>
      <div class="trust-chips reveal" style="transition-delay:240ms">
        <span class="trust-chip">без предоплаты</span>
        <span class="trust-chip">ответ за 2 часа</span>
        <span class="trust-chip">NDA по запросу</span>
      </div>
    </div>
  </section>

  <!-- VIDEO DEMO -->
  <section style="background:var(--dark-bg);padding:0 0 72px">
    <div class="container reveal" style="max-width:1000px;width:100%">
      <div class="video-card" style="aspect-ratio:16/9">
        <div class="video-card-chrome">
          <span class="dot"></span><span class="dot"></span><span class="dot"></span>
          <span class="url">coordo.whatdadev.ru — согласование договора</span>
        </div>
        <video
          src="/video/coordo-demo.mp4"
          autoplay
          muted
          loop
          playsinline
          style="width:100%;height:100%;object-fit:cover;display:block;padding-top:32px"
        ></video>
      </div>
      <p style="text-align:center;font-size:13px;color:var(--dark-muted);margin-top:14px">
        Запись реального процесса согласования договора в Coordo
      </p>
    </div>
  </section>

  <!-- ПРОБЛЕМА -->
  <section class="section alt">
    <div class="container">
      <div class="eyebrow">Почему так происходит</div>
      <h2>Документооборот в почте и мессенджерах — это хаос</h2>
      <div class="grid grid-3" style="margin-top:24px">
        <div class="card">
          <h3>Непонятно где документ</h3>
          <p>Письмо согласовали или нет? У кого сейчас? Почему завис? Ответов нет — только звонки и уточнения.</p>
        </div>
        <div class="card">
          <h3>Сроки срываются</h3>
          <p>Один человек в отпуске — договор стоит. Нет напоминаний, нет эскалации, нет замещений.</p>
        </div>
        <div class="card">
          <h3>Разработка слишком дорога</h3>
          <p>Написать СЭД с нуля — месяцы работы и миллионы рублей. Любая правка маршрута — новая задача разработчику.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ЧТО ТАКОЕ COORDO -->
  <section class="section">
    <div class="container">
      <div class="eyebrow">Решение</div>
      <h2>Coordo — готовые контуры ЭДО на ELMA365</h2>
      <p class="lead">Три контура из коробки. Маршруты настраиваются в интерфейсе без кода — администратор меняет схему согласования за минуты, не за релиз.</p>
      <div class="grid grid-3" style="margin-top:32px">
        <a class="card" href="/products/express/dogovory/">
          <div style="font-size:28px;margin-bottom:12px">📄</div>
          <h3>Договоры</h3>
          <p>Полный цикл: инициация → согласование → подпись → архив. Реестр, статусы, контроль сроков.</p>
        </a>
        <a class="card" href="/products/express/ord/">
          <div style="font-size:28px;margin-bottom:12px">📋</div>
          <h3>ОРД и приказы</h3>
          <p>Согласование и ознакомление с распорядительными документами. Факт ознакомления фиксируется.</p>
        </a>
        <a class="card" href="/products/express/korrespondenciya/">
          <div style="font-size:28px;margin-bottom:12px">✉️</div>
          <h3>Корреспонденция</h3>
          <p>Регистрация входящих и исходящих, поручения, журналы, контроль исполнения.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- КАК РАБОТАЕТ -->
  <section class="section alt">
    <div class="container">
      <div class="eyebrow">Как это работает</div>
      <h2>От демо до рабочего ЭДО — за 4–8 недель</h2>
      <div class="steps" style="margin-top:32px">
        <div class="step reveal">
          <div class="num">1</div>
          <h3>Демо на ваших документах</h3>
          <p>Показываем продукт на реальных примерах из вашей отрасли. 30–45 минут онлайн. Бесплатно.</p>
        </div>
        <div class="step reveal" style="transition-delay:80ms">
          <div class="num">2</div>
          <h3>Установка</h3>
          <p>Разворачиваем готовые контуры на вашей ELMA365. Никакой разработки — только конфигурация.</p>
        </div>
        <div class="step reveal" style="transition-delay:160ms">
          <div class="num">3</div>
          <h3>Настройка под ваши регламенты</h3>
          <p>Маршруты, роли, шаблоны, замещения — адаптируем без кода под ваши процессы.</p>
        </div>
        <div class="step reveal" style="transition-delay:240ms">
          <div class="num">4</div>
          <h3>Запуск и обучение</h3>
          <p>Обучаем команду и передаём управление. Дальше вы управляете сами — разработчик не нужен.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ЦЕНА -->
  <section class="section">
    <div class="container center" style="max-width:640px">
      <div class="eyebrow">Стоимость</div>
      <h2>Один раз — и навсегда</h2>
      <div style="font-size:clamp(36px,5vw,52px);font-weight:700;color:var(--accent);margin:16px 0 8px">от 690 000 ₽</div>
      <p class="muted">Ядро + 3 контура · установка и адаптация · 6 месяцев поддержки · обновления.<br>Без доплат за пользователей. Без ежемесячной подписки.</p>
      <div class="btn-row" style="justify-content:center;margin-top:24px">
        <a class="btn" href="/contacts/">Записаться на демо</a>
        <a class="btn-secondary" href="/products/express/pricing/">Что входит в цену</a>
      </div>
    </div>
  </section>

  <!-- ПОЧЕМУ МЫ -->
  <section class="section alt">
    <div class="container">
      <div class="eyebrow">Почему WhatDaDev</div>
      <h2>Специализация, а не «ещё один интегратор»</h2>
      <div class="grid grid-3" style="margin-top:24px">
        <div class="card">
          <h3>Только ELMA365</h3>
          <p>Не распыляемся на десятки платформ. Знаем продукт глубоко — это ускоряет внедрение и снижает риски.</p>
        </div>
        <div class="card">
          <h3>Фиксированный результат</h3>
          <p>Вы знаете что получите до старта. Не «сделаем систему», а «запустим согласование договоров за 6 недель».</p>
        </div>
        <div class="card">
          <h3>Без разработки</h3>
          <p>Маршруты, роли, шаблоны — настраиваются в интерфейсе. После запуска вы сами меняете процессы.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="hero" style="min-height:auto">
    <div class="container center" style="padding-top:64px;padding-bottom:64px;width:100%">
      <h2 style="color:#fff;max-width:560px;margin:0 auto 16px">Посмотрите как Coordo работает на ваших документах</h2>
      <p style="color:var(--dark-muted);margin-bottom:28px">30 минут онлайн. Без обязательств. Покажем на реальном примере.</p>
      <div class="btn-row" style="justify-content:center">
        <a class="btn" href="/contacts/">Записаться на демо</a>
      </div>
    </div>
  </section>

</Base>
