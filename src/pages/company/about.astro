---
import Base from "../../layouts/Base.astro";
import { team } from "../../data/team.js";
const title = "О компании WhatDaDev — эксперты ELMA365 | РФ и КЗ";
const description = "WhatDaDev — внедрение ELMA365 и собственные продукты. 4+ года, сертифицированные эксперты, 12 внедрений. Работаем в РФ и Казахстане.";
---
<Base title={title} description={description}>
  <section class="hero">
    <div class="container">
      <h1>О WhatDaDev — сертифицированные эксперты ELMA365</h1>
      <p class="lead">Внедряем ELMA365 и развиваем собственные продукты для документооборота. Работаем в России и Казахстане.</p>
      <div class="proof"><span><b>4+</b> года на ELMA365</span><span><b>12</b> внедрений</span><span>сертифицированные эксперты</span></div>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <h2>Чем мы отличаемся</h2>
      <div class="grid grid-3" style="margin-top:24px">
        <div class="card"><h3>Dogfooding</h3><p>Сами работаем на ELMA365 и своих продуктах — внедряем по реальному опыту.</p></div>
        <div class="card"><h3>Продукты, а не только услуги</h3><p>Готовые решения из коробки ускоряют запуск и снижают стоимость.</p></div>
        <div class="card"><h3>Под поддержку</h3><p>Решения, которыми клиент управляет сам, без сложных доработок.</p></div>
      </div>
    </div>
  </section>
  <section class="section alt">
    <div class="container">
      <div class="eyebrow">Команда</div>
      <h2>Мы будем с вами работать</h2>
      <div class="team">
        {team.map((m) => (
          <div class="member reveal">
            {m.photo ? <img class="avatar-photo" src={m.photo} alt={m.name} width="64" height="64" loading="lazy" /> : <div class="avatar">{m.initials}</div>}
            <h3>{m.name}</h3>
            <span class="role">{m.role}</span>
            <p>{m.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  <section class="hero">
    <div class="container center">
      <h2 style="color:#fff">Обсудим вашу задачу</h2>
      <div class="btn-row" style="justify-content:center"><a class="btn" href="/contacts/">Связаться</a></div>
    </div>
  </section>
</Base>
