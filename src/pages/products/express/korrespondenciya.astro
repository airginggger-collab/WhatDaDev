---
import Base from "../../../layouts/Base.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
const title = "Учёт корреспонденции на ELMA365 — канцелярия | WhatDaDev";
const description = "Регистрация входящей и исходящей корреспонденции на ELMA365: журналы, поручения, контроль исполнения. Электронная канцелярия из коробки.";
const faq = [
  ["Поддерживается автонумерация и журналы регистрации?", "Да — настраиваемые журналы и нумерация для входящих и исходящих."],
  ["Можно ставить поручения по письму?", "Да, с ответственными, сроками и контролем исполнения."],
  ["Это часть ELMA365?", "Да, готовый контур на ELMA365 в составе Экспресс внедрения (Coordo)."],
];
const jsonld = [{ "@context": "https://schema.org", "@type": "FAQPage", mainEntity: faq.map(([q, a]) => ({ "@type": "Question", name: q, acceptedAnswer: { "@type": "Answer", text: a } })) }];
---
<Base title={title} description={description} jsonld={jsonld}>
  <section class="hero">
    <div class="container">
      <Breadcrumbs items={[{ name: "Главная", href: "/" }, { name: "Экспресс внедрение", href: "/products/express/" }, { name: "Корреспонденция" }]} />
      <div class="eyebrow" style="color:#8FBBE0">Экспресс внедрение (Coordo) · Контур</div>
      <h1>Учёт входящей и исходящей корреспонденции на ELMA365</h1>
      <p class="lead">Электронная канцелярия: регистрация писем, резолюции, поручения и контроль исполнения — в едином журнале, а не в бумажных книгах.</p>
      <div class="btn-row"><a class="btn" href="/contacts/">Записаться на демо</a></div>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <h2>Когда канцелярия — это бумажные журналы</h2>
      <div class="grid grid-3" style="margin-top:24px">
        <div class="card"><p>Письма теряются, дубли регистрации, нет единого учёта.</p></div>
        <div class="card"><p>Резолюции и поручения не доходят или не контролируются.</p></div>
        <div class="card"><p>Найти прошлогоднее письмо — отдельный квест.</p></div>
      </div>
    </div>
  </section>
  <section class="section alt">
    <div class="container">
      <h2>Письмо под контролем с момента регистрации</h2>
      <div class="grid grid-2" style="margin-top:24px">
        <div class="card"><h3>Регистрация</h3><p>Входящие и исходящие с автонумерацией.</p></div>
        <div class="card"><h3>Резолюции и поручения</h3><p>Назначаем ответственных и сроки.</p></div>
        <div class="card"><h3>Журналы</h3><p>Единые электронные журналы регистрации, поиск по реквизитам.</p></div>
        <div class="card"><h3>Контроль исполнения</h3><p>Видно просроченные и исполненные поручения.</p></div>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="container faq">
      <h2>Частые вопросы</h2>
      {faq.map(([q, a]) => (<details><summary>{q}</summary><p>{a}</p></details>))}
      <div class="btn-row"><a class="btn" href="/contacts/">Записаться на демо</a></div>
    </div>
  </section>
</Base>
