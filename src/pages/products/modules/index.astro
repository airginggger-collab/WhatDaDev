---
import Base from "../../../layouts/Base.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
const title = "Модули и решения для ELMA365 | WhatDaDev";
const description = "Готовые модули для ELMA365: замещения, аудит СМК, экспорт объектной модели, связанные процессы, управление документами, коннектор RabbitMQ.";
const itemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Готовые модули и решения для ELMA365",
  description,
  url: "https://whatdadev.ru/products/modules/",
  inLanguage: "ru",
};
const modules = [
  { name: "Замещения", desc: "Самостоятельная настройка замещений без участия администратора: задачи не встают из-за отпусков и отсутствий.", href: "/products/modules/zameshcheniya/" },
  { name: "Аудит СМК", desc: "Проведение аудитов согласно национальному стандарту РФ ГОСТ Р ИСО 19011-2021.", href: null },
  { name: "Экспорт объектной модели", desc: "Экспорт объектной модели и параметров решения в документ Word.", href: null },
  { name: "Связанные бизнес-процессы", desc: "Просмотр всех связанных с элементом бизнес-процессов прямо в его карточке — инструмент администратора.", href: null },
  { name: "Визуализация и управление документами", desc: "Быстрый доступ, скачивание, управление и обмен документами и файлами в одном решении.", href: null },
  { name: "Коннектор RabbitMQ", desc: "Подключение ELMA365 к нескольким серверам RabbitMQ и нескольким очередям сообщений.", href: null },
];
---
<Base title={title} description={description} jsonld={[itemList]}>
  <section class="hero">
    <div class="container">
      <Breadcrumbs items={[{ name: "Главная", href: "/" }, { name: "Продукты" }]} />
      <h1>Готовые модули и решения для ELMA365</h1>
      <p class="lead">Отдельные модули, которые усиливают вашу ELMA365 — подключаются быстро, без разработки с нуля.</p>
      <div class="btn-row"><a class="btn" href="/contacts/">Записаться на демо</a></div>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="grid grid-3">
        {modules.map((m) => m.href
          ? (<a class="card" href={m.href}><h3>{m.name}</h3><p>{m.desc}</p></a>)
          : (<div class="card"><h3>{m.name}</h3><p>{m.desc}</p><span class="tag" style="margin-top:10px">страница скоро</span></div>))}
      </div>
    </div>
  </section>
</Base>
