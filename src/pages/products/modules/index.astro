---
import Base from "../../../layouts/Base.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import { items as modules } from "../../../data/modules.json";
const title = "Модули и решения для ELMA365 | WhatDaDev";
const description = "Готовые модули для ELMA365: замещения, аудит СМК, экспорт объектной модели, связанные процессы, управление документами, коннектор RabbitMQ.";
const itemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Готовые модули и решения для ELMA365",
  description,
  url: "https://whatdadev.ru/products/modules/",
  inLanguage: "ru",
};
---
<Base title={title} description={description} jsonld={[itemList]}>
  <section class="hero">
    <div class="container">
      <Breadcrumbs items={[{ name: "Главная", href: "/" }, { name: "Продукты" }]} />
      <h1>Готовые модули и решения для ELMA365</h1>
      <p class="lead">Отдельные модули, которые усиливают вашу ELMA365 и подключаются быстро, без разработки с нуля.</p>
      <div class="btn-row"><a class="btn" href="/contacts/">Записаться на демо</a></div>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="grid grid-3">
        {modules.map((m) => m.href
          ? (<a class="card" href={m.href}><h3>{m.name}</h3><p>{m.desc}</p></a>)
          : (<div class="card"><h3>{m.name}</h3><p>{m.desc}</p><span class="tag" style="margin-top:10px">страница скоро</span></div>))}
      </div>
    </div>
  </section>
</Base>
