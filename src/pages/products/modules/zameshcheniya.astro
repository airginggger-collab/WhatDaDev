---
import Base from "../../../layouts/Base.astro";
const title = "Замещение сотрудников в ELMA365 | WhatDaDev";
const description = "Модуль замещений для ELMA365: автоматическая передача задач при отпуске и отсутствии. Согласования не встают.";
const faq = [
  ["Можно настроить замещение на период отпуска заранее?", "Да — с датами начала и окончания; передача и возврат происходят автоматически."],
  ["Заместитель видит, что задачи не его?", "Да — задачи помечены как полученные по замещению."],
  ["Это часть ELMA365?", "Да, готовый модуль на ELMA365 в линейке Экспресс внедрения (Coordo)."],
];
const jsonld = [{ "@context": "https://schema.org", "@type": "FAQPage", mainEntity: faq.map(([q, a]) => ({ "@type": "Question", name: q, acceptedAnswer: { "@type": "Answer", text: a } })) }];
---
<Base title={title} description={description} jsonld={jsonld}>
  <section class="hero">
    <div class="container">
      <div class="eyebrow" style="color:#a5b4fc">Экспресс внедрение (Coordo) · Модуль</div>
      <h1>Замещение сотрудников в ELMA365 — согласования не встают</h1>
      <p class="lead">Сотрудник в отпуске или на больничном — его задачи автоматически уходят заместителю. Никаких «договор завис, пока Иванов вернётся».</p>
      <div class="btn-row"><a class="btn" href="/contacts/">Записаться на демо</a></div>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <h2>Один отпуск — и согласование стоит неделю</h2>
      <div class="grid grid-3" style="margin-top:24px">
        <div class="card"><p>Задачи копятся у отсутствующего сотрудника.</p></div>
        <div class="card"><p>Никто не знает, кто замещает и что делать.</p></div>
        <div class="card"><p>Сроки срываются, ответственность размыта.</p></div>
      </div>
    </div>
  </section>
  <section class="section alt">
    <div class="container">
      <h2>Настроили замещение — и процессы не зависят от отпусков</h2>
      <div class="grid grid-2" style="margin-top:24px">
        <div class="card"><h3>Назначение заместителя</h3><p>Кто кого замещает и на какой период.</p></div>
        <div class="card"><h3>Автопередача задач</h3><p>Новые и текущие задачи уходят заместителю автоматически.</p></div>
        <div class="card"><h3>Уведомления</h3><p>Заместитель и руководитель в курсе.</p></div>
        <div class="card"><h3>Возврат</h3><p>По выходу сотрудника всё возвращается к нему.</p></div>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="container faq">
      <h2>Частые вопросы</h2>
      {faq.map(([q, a]) => (<details><summary>{q}</summary><p>{a}</p></details>))}
      <div class="btn-row"><a class="btn" href="/contacts/">Записаться на демо</a></div>
    </div>
  </section>
</Base>
