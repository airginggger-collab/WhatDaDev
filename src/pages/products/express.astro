---
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
const title = "Экспресс‑внедрение ЭДО на ELMA365 из коробки | WhatDaDev";
const description = "Готовый электронный документооборот на ELMA365: договоры, ОРД, корреспонденция. Запуск без долгой разработки. Разово, без подписки.";
const faq = [
  ["Сколько времени занимает внедрение?", "Экспресс внедрение рассчитано на 4–8 недель. Первые пользователи начинают работать уже через 2–3 недели — поэтапно, без простоя."],
  ["Нужна ли лицензия ELMA365?", "Да, ELMA365 — отдельный продукт. Мы помогаем подобрать нужный тариф и можем оформить лицензию. Стоимость лицензий не входит в цену Экспресс внедрения."],
  ["Что если нам нужны нестандартные доработки?", "Экспресс внедрение покрывает типовые сценарии. Для уникальных процессов мы предлагаем услугу разработки под заказ — обсудим на демо."],
  ["Есть ли поддержка после запуска?", "Да, в пакет входит сопровождение на старте. После этого доступна техподдержка по отдельному договору."],
  ["Работаете ли вы с компаниями из Казахстана?", "Да, мы работаем по всей России и Казахстане. Все документы оформляем дистанционно."],
];
const jsonld = [
  {
    "@context": "https://schema.org", "@type": "SoftwareApplication",
    name: "Экспресс внедрение (Coordo)", applicationCategory: "BusinessApplication",
    operatingSystem: "ELMA365", url: "https://whatdadev.ru/products/express/",
    description: "Готовый ЭДО на ELMA365: согласование договоров, ОРД и корреспонденции. Маршруты без кода. Разово, без подписки.",
    offers: { "@type": "Offer", price: "690000", priceCurrency: "RUB", availability: "https://schema.org/InStock", url: "https://whatdadev.ru/products/express/" },
    provider: { "@type": "Organization", name: "WhatDaDev", url: "https://whatdadev.ru" },
  },
  { "@context": "https://schema.org", "@type": "FAQPage", mainEntity: faq.map(([q, a]) => ({ "@type": "Question", name: q, acceptedAnswer: { "@type": "Answer", text: a } })) },
];
---
<Base title={title} description={description} jsonld={jsonld}>
  <section class="hero">
    <div class="container hero-split">
      <div>
        <Breadcrumbs items={[{ name: "Главная", href: "/" }, { name: "Продукты", href: "/products/modules/" }, { name: "Экспресс внедрение" }]} />
        <div class="eyebrow" style="color:#9AD1AF">Продукт · Экспресс внедрение (Coordo)</div>
        <h1>Экспресс‑внедрение ЭДО на ELMA365 — из коробки, без месяцев разработки</h1>
        <p class="lead">Готовые контуры согласования договоров, ОРД и корреспонденции на ELMA365. Запуск за недели. Один раз — без подписки и доплат за пользователей.</p>
        <div class="btn-row"><a class="btn" href="/contacts/">Записаться на демо</a></div>
        <div class="proof"><span><b>4+</b> года на ELMA365</span><span>с момента релиза платформы</span><span>РФ и КЗ</span></div>
      </div>
      <div class="dash" data-p="0" style="--p:0">
        <div class="dash-head">
          <h3>Согласование договоров</h3>
          <span class="tag">демо-данные</span>
        </div>
        <div class="kpis">
          <div class="kpi"><b>2 дня</b><span>средний срок</span></div>
          <div class="kpi"><b>14</b><span>в работе</span></div>
          <div class="kpi"><b>0</b><span>просрочено</span></div>
        </div>
        <div class="bars reveal in">
          <div class="bar"><div class="bar-fill" style="--h:100%;transition-delay:.05s"></div><small>янв</small></div>
          <div class="bar"><div class="bar-fill" style="--h:78%;transition-delay:.15s"></div><small>фев</small></div>
          <div class="bar"><div class="bar-fill" style="--h:56%;transition-delay:.25s"></div><small>мар</small></div>
          <div class="bar"><div class="bar-fill" style="--h:33%;transition-delay:.35s"></div><small>апр</small></div>
          <div class="bar"><div class="bar-fill" style="--h:22%;transition-delay:.45s"></div><small>май</small></div>
        </div>
        <p class="dash-cap">Срок согласования договора, дни.</p>
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <h2>Документооборот «с нуля» — это долго, дорого и непредсказуемо</h2>
      <div class="grid grid-3" style="margin-top:24px">
        <div class="card"><p>Месяцы на ТЗ, разработку и отладку до первого результата.</p></div>
        <div class="card"><p>Бюджет растёт: каждая правка маршрута — новая задача разработчику.</p></div>
        <div class="card"><p>Риск получить сырое решение, которое дорого поддерживать.</p></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Три готовых контура из коробки</h2>
      <div class="grid grid-3" style="margin-top:24px">
        <a class="card" href="/products/express/dogovory/"><h3>Управление договорами</h3><p>Полный цикл от инициации до архива: маршрут, сроки, единый реестр.</p></a>
        <a class="card" href="/products/express/ord/"><h3>ОРД и приказы</h3><p>Согласование и ознакомление с распорядительными документами, контроль исполнения.</p></a>
        <a class="card" href="/products/express/korrespondenciya/"><h3>Корреспонденция</h3><p>Регистрация входящих и исходящих, поручения, журналы.</p></a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="eyebrow">Ядро</div>
      <h2>Маршруты согласования настраиваются без кода</h2>
      <p class="lead">Этапы, условия, сроки и делегирование задаёт администратор сам — в интерфейсе. Поменялся регламент — поменяли маршрут за минуты, не за релиз.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="eyebrow">Как запускаем</div>
      <h2>От демо до работающего ЭДО — за недели</h2>
      <div class="steps">
        <div class="step reveal"><div class="num">1</div><h3>Демо и аудит</h3><p>Показываем продукт на ваших документах, фиксируем маршруты согласования.</p></div>
        <div class="step reveal"><div class="num">2</div><h3>Установка</h3><p>Разворачиваем готовые контуры на вашей ELMA365.</p></div>
        <div class="step reveal"><div class="num">3</div><h3>Настройка</h3><p>Адаптируем маршруты, роли и шаблоны без кода под ваши регламенты.</p></div>
        <div class="step reveal"><div class="num">4</div><h3>Запуск</h3><p>Обучаем команду и передаём — дальше управляете сами.</p></div>
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container center">
      <h2>Один раз — и навсегда. Без подписки</h2>
      <div class="price" style="color:var(--accent);margin:8px 0">от 690 000 ₽</div>
      <p class="muted">Ядро + готовые контуры · установка и адаптация · 6 месяцев поддержки · обновления. Без доплат за пользователей.</p>
      <div class="btn-row" style="justify-content:center"><a class="btn" href="/contacts/">Записаться на демо</a></div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:760px">
      <div class="eyebrow reveal">FAQ</div>
      <h2 class="reveal">Частые вопросы</h2>
      <div class="faq reveal" style="margin-top:32px">
        {faq.map(([q, a]) => (
          <div class="faq-item">
            <button class="faq-q" aria-expanded="false">{q}</button>
            <div class="faq-a">{a}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>
