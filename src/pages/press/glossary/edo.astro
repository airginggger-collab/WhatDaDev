---
import Base from "../../../layouts/Base.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";

const title = "ЭДО — что это такое: определение и применение | WhatDaDev";
const description = "Что такое ЭДО (Электронный документооборот): определение, применение в документообороте и автоматизации процессов.";

const faq = [
  ["Чем ЭДО отличается от сканирования бумажных документов?", "Сканирование — это цифровая копия бумажного оригинала, у которой нет юридической силы. ЭДО — это документ, изначально созданный и подписанный в электронном виде с помощью ЭЦП. Такой документ равнозначен бумажному без распечатки."],
  ["Нужна ли ЭЦП для внутреннего ЭДО?", "Для внутреннего документооборота достаточно простой или усиленной неквалифицированной подписи. КЭП (квалифицированная ЭЦП) обязательна только для обмена документами с контрагентами и госорганами."],
  ["Как ЭДО работает в ELMA365?", "В ELMA365 есть встроенный модуль документооборота: маршруты согласования, электронные подписи, архив и поиск. Можно настроить любые типы документов и цепочки согласования без разработки."],
  ["Сколько времени занимает внедрение ЭДО?", "Базовый ЭДО на ELMA365 запускается за 4–6 недель. Полноценное внедрение с настройкой под процессы компании, интеграциями и обучением — 2–4 месяца. Через продукт Экспресс внедрение (Coordo) старт возможен за 2 недели."],
];

const jsonld = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: "ЭДО: что это такое",
    description,
    author: { "@type": "Organization", name: "WhatDaDev", url: "https://whatdadev.ru" },
    publisher: { "@type": "Organization", name: "WhatDaDev", url: "https://whatdadev.ru" },
    url: "https://whatdadev.ru/press/glossary/edo/",
    inLanguage: "ru",
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faq.map(([q, a]) => ({
      "@type": "Question",
      name: q,
      acceptedAnswer: { "@type": "Answer", text: a },
    })),
  },
];
---

<Base title={title} description={description} jsonld={jsonld}>
  <section class="hero">
    <div class="container">
      <Breadcrumbs items={[
        { name: "Главная", href: "/" },
        { name: "Пресс-центр", href: "/press/" },
        { name: "Глоссарий", href: "/press/glossary/" },
        { name: "ЭДО" },
      ]} />
      <div class="eyebrow" style="color:#9AD1AF">Глоссарий</div>
      <h1>ЭДО — что это такое</h1>
      <p class="lead">
        Электронный документооборот (ЭДО) — система создания, подписания, передачи и хранения документов в электронном виде без бумажных оригиналов. Документы имеют юридическую силу благодаря электронной цифровой подписи (ЭЦП).
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container prose">
      <h2>Что такое ЭДО и зачем он нужен</h2>
      <p>
        ЭДО заменяет бумажный документооборот: договоры, счета, акты, приказы и служебные записки создаются, согласовываются и подписываются в цифровой среде. Документ не нужно распечатывать, подписывать вручную и везти курьером — весь процесс проходит внутри системы.
      </p>
      <p>
        Ключевое преимущество — скорость и прозрачность. Согласование договора, которое раньше занимало 5–7 дней, в ЭДО проходит за несколько часов. При этом в любой момент видно, у кого документ находится, кто уже подписал и почему завис.
      </p>
      <p>
        ЭДО делится на два контура: <strong>внутренний</strong> — документы внутри компании (приказы, служебки, заявления) и <strong>внешний</strong> — обмен с контрагентами и госорганами через операторов ЭДО (СБИС, Диадок, Контур и др.).
      </p>

      <h2>Как ЭДО применяется в ELMA365</h2>
      <p>
        <a href="/elma365/">ELMA365</a> включает полноценный модуль документооборота. В нём настраиваются маршруты согласования для любых типов документов: по ролям, подразделениям или индивидуально. Подписание — встроенной ЭЦП или через интеграцию с внешними сервисами.
      </p>
      <p>
        Особенность платформы — документ живёт внутри бизнес-процесса. Например, договор не просто согласовывается сам по себе: он привязан к сделке в CRM, автоматически уходит на подпись после одобрения коммерческого директора и попадает в архив по завершении. Документ и процесс — единое целое.
      </p>
      <p>
        Для компаний, которым нужен готовый ЭДО без длительного проекта, подходит <a href="/products/express/">Экспресс внедрение (Coordo)</a> — преднастроенный контур документооборота на ELMA365, который запускается за 2 недели.
      </p>

      <h2>Пример из практики</h2>
      <p>
        Производственная компания согласовывала договоры поставки в среднем 8 дней: обходил бумажный экземпляр юриста, финдиректора, генерального. После внедрения ЭДО на ELMA365 маршрут согласования занял 1 день — документ параллельно уходит всем участникам, каждый видит комментарии коллег и подписывает в один клик.
      </p>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <h2>Частые вопросы об ЭДО</h2>
      <div class="faq">
        {faq.map(([q, a]) => (
          <div class="faq-item">
            <button class="faq-q" aria-expanded="false">{q}</button>
            <div class="faq-a">
              <p>{a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="text-align:center">
      <div class="eyebrow" style="color:#9AD1AF">Внедрение ЭДО</div>
      <h2>Запустите ЭДО на ELMA365 за 2 недели</h2>
      <p class="muted" style="max-width:520px;margin:0 auto 2rem">
        Готовый контур документооборота с настроенными маршрутами согласования, архивом и подписанием. Без длительного проекта.
      </p>
      <div class="btn-row">
        <a href="/contacts/" class="btn">Обсудить внедрение</a>
        <a href="/products/express/" class="btn" style="background:transparent;border:1px solid var(--color-accent)">Экспресс внедрение (Coordo)</a>
      </div>
    </div>
  </section>
</Base>

<script>
  document.querySelectorAll(".faq-q").forEach((btn) => {
    btn.addEventListener("click", () => {
      const expanded = btn.getAttribute("aria-expanded") === "true";
      btn.setAttribute("aria-expanded", String(!expanded));
    });
  });
</script>
