---
import Base from "../../../layouts/Base.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import { getCollection } from "astro:content";
const title = "Глоссарий по ЭДО и автоматизации процессов | WhatDaDev";
const description = "Словарь терминов: ЭДО, СЭД, BPM, КЭДО, ОРД, ЭЦП, ЮЗЭДО и другие понятия документооборота.";
const entries = await getCollection("glossary", ({ data }) => !data.draft);
const terms = entries
  .map((e) => ({ slug: e.id, name: e.data.name, order: e.data.order }))
  .sort((a, b) => a.order - b.order);
---
<Base title={title} description={description}>
  <section class="hero">
    <div class="container">
      <Breadcrumbs items={[{ name:"Главная", href:"/" }, { name:"Пресс-центр", href:"/press/" }, { name:"Глоссарий" }]} />
      <h1>Глоссарий по ЭДО и автоматизации процессов</h1>
      <p class="lead">Словарь терминов: от ЭДО и СЭД до BPM и ЮЗЭДО. Коротко и по делу.</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="grid grid-3">
        {terms.map(t => (
          <a class="card" href={"/press/glossary/" + t.slug + "/"}><h3>{t.name}</h3><p class="muted">Читать &rarr;</p></a>
        ))}
      </div>
    </div>
  </section>
</Base>
