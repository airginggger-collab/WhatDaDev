---
import Base from "../../../layouts/Base.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
const title = "BPM — что это такое: определение и применение | WhatDaDev";
const description = "Что такое BPM (Business Process Management): определение, применение в документообороте и автоматизации процессов.";
const faq = [
  ["Чем BPM отличается от обычной автоматизации?", "Автоматизация убирает ручной труд на отдельных шагах. BPM управляет сквозным процессом целиком — от инициации до архива, включая согласования, контроль сроков и аналитику."],
  ["Нужна ли BPM-система небольшой компании?", "Да, если у вас есть повторяющиеся процессы с несколькими участниками: договоры, заявки, согласования. Даже 20 человек выигрывают от единого маршрута вместо переписки в мессенджерах."],
  ["Что такое BPMN?", "BPMN (Business Process Model and Notation) — графическая нотация для описания процессов. В ELMA365 процессы рисуются именно в BPMN: это позволяет аналитику и разработчику говорить на одном языке."],
  ["Как BPM связан с ЭДО?", "ЭДО — частный случай BPM: документ проходит маршрут согласования, подписывается, уходит контрагенту. BPM-движок следит за сроками, напоминает исполнителям и фиксирует каждый шаг в журнале."],
];
const jsonld = [
  { "@context":"https://schema.org","@type":"Article", headline:"BPM: что это такое", description, author:{"@type":"Organization","name":"WhatDaDev","url":"https://whatdadev.ru"}, publisher:{"@type":"Organization","name":"WhatDaDev","url":"https://whatdadev.ru"}, url:"https://whatdadev.ru/press/glossary/bpm/", inLanguage:"ru" },
  { "@context":"https://schema.org","@type":"FAQPage", mainEntity:faq.map(([q,a])=>({ "@type":"Question",name:q,acceptedAnswer:{"@type":"Answer",text:a} })) },
];
---
<Base title={title} description={description} jsonld={jsonld}>

  <section class="hero">
    <div class="container">
      <Breadcrumbs items={[{ name:"Главная", href:"/" }, { name:"Пресс-центр", href:"/press/" }, { name:"Глоссарий", href:"/press/glossary/" }, { name:"BPM" }]} />
      <div class="eyebrow" style="color:#9AD1AF">Глоссарий</div>
      <h1>BPM — что это такое</h1>
      <p class="lead">Business Process Management — управление бизнес-процессами: подход и класс систем, которые переводят хаотичную работу людей в прозрачные, контролируемые маршруты.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="prose">
        <h2>Что такое BPM</h2>
        <p>BPM (Business Process Management) — это дисциплина управления, при которой работа организации описывается как набор сквозных процессов: каждый шаг фиксирован, у каждого шага есть ответственный и срок. В отличие от задачника или CRM, BPM-система не просто хранит данные — она ведёт объект (заявку, договор, обращение) по заданному маршруту и контролирует исполнение.</p>
        <p>Технически BPM строится на процессном движке: он читает схему процесса в нотации BPMN, создаёт экземпляры при каждом запуске, распределяет задачи исполнителям и пишет полный журнал событий. Это делает процесс воспроизводимым и измеримым.</p>

        <h2>Зачем это бизнесу</h2>
        <p>Без BPM процессы живут в головах сотрудников и мессенджерах. Договор согласовывается неделю, потому что никто не знает, у кого он завис. Заявка теряется при смене исполнителя. BPM решает три задачи:</p>
        <ul>
          <li><strong>Прозрачность</strong> — руководитель видит, на каком шаге находится любой объект прямо сейчас.</li>
          <li><strong>Соблюдение регламентов</strong> — система не даст пропустить обязательное согласование или подпись.</li>
          <li><strong>Аналитика</strong> — после накопления данных становится видно, где процесс узкий и где теряется время.</li>
        </ul>

        <h2>BPM в ELMA365</h2>
        <p>ELMA365 — российская low-code платформа с встроенным BPM-движком. Процессы рисуются в визуальном дизайнере в нотации BPMN 2.0, без написания кода. Типовые сценарии: согласование договоров и приказов, обработка входящих обращений, онбординг сотрудников, цепочки закупок.</p>
        <p>Пример: компания переводит согласование командировок на ELMA365. Сотрудник подаёт заявку в форме, система автоматически маршрутизирует её к руководителю, затем в бухгалтерию, затем закрывает задачу и уведомляет о результате. Среднее время согласования сокращается с 3 дней до 4 часов.</p>
        <p>Подробнее о платформе — в разделе <a href="/elma365/">ELMA365</a>. Про внедрение BPM-системы с нуля читайте в статье <a href="/press/articles/bpm-sistema/">«Как выбрать BPM-систему»</a>.</p>
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <h2>Частые вопросы о BPM</h2>
      <div class="faq">
        {faq.map(([q, a]) => (
          <div class="faq-item">
            <button class="faq-q" aria-expanded="false">{q}</button>
            <div class="faq-a">{a}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="text-align:center">
      <p class="eyebrow" style="color:#9AD1AF">Готовы автоматизировать процессы?</p>
      <h2>Внедрим BPM под ваши задачи</h2>
      <p class="muted">Покажем, как процессы вашей компании лягут на ELMA365 — на демо без обязательств.</p>
      <div class="btn-row">
        <a href="/contacts/" class="btn">Обсудить проект</a>
      </div>
    </div>
  </section>

</Base>
