---
import Base from "../../../layouts/Base.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
const title = "Service Desk — что это такое: определение и применение | WhatDaDev";
const description = "Что такое Service Desk (сервисный стол): определение, применение в документообороте и автоматизации процессов на базе ELMA365.";
const faq = [
  ["Чем Service Desk отличается от Help Desk?", "Help Desk — реактивная поддержка: принял заявку, решил проблему. Service Desk — более широкая концепция: управление всем жизненным циклом обращений, каталог услуг, SLA, отчётность и непрерывное улучшение процессов."],
  ["Можно ли внедрить Service Desk без отдельной ITSM-системы?", "Да. ELMA365 позволяет построить полноценный сервисный стол на базе BPM-платформы — без покупки специализированного ITSM-продукта. Это экономит бюджет и упрощает интеграцию с другими процессами компании."],
  ["Сколько времени занимает внедрение Service Desk?", "Базовый контур (приём заявок, маршрутизация, уведомления, SLA) запускается за 4–6 недель в рамках Экспресс внедрения (Coordo). Сложные каталоги услуг и интеграции с внешними системами — 2–4 месяца."],
  ["Для каких отделов подходит Service Desk на ELMA365?", "Для любого отдела, который получает внутренние или внешние запросы: ИТ, АХО, HR, бухгалтерия, юридический отдел. Один экземпляр платформы обслуживает несколько направлений одновременно."],
];
const jsonld = [
  { "@context":"https://schema.org","@type":"Article", headline:"Service Desk: что это такое", description, author:{"@type":"Organization","name":"WhatDaDev","url":"https://whatdadev.ru"}, publisher:{"@type":"Organization","name":"WhatDaDev","url":"https://whatdadev.ru"}, url:"https://whatdadev.ru/press/glossary/service-desk/", inLanguage:"ru" },
  { "@context":"https://schema.org","@type":"FAQPage", mainEntity:faq.map(([q,a])=>({ "@type":"Question",name:q,acceptedAnswer:{"@type":"Answer",text:a} })) },
];
---
<Base title={title} description={description} jsonld={jsonld}>

  <section class="hero">
    <div class="container">
      <Breadcrumbs items={[{ name:"Главная", href:"/" }, { name:"Пресс-центр", href:"/press/" }, { name:"Глоссарий", href:"/press/glossary/" }, { name:"Service Desk" }]} />
      <div class="eyebrow" style="color:#9CC4B0">Глоссарий</div>
      <h1>Service Desk — что это такое</h1>
      <p class="lead">Service Desk (сервисный стол) — централизованная точка приёма, обработки и контроля всех обращений внутри компании: от ИТ-инцидентов до заявок на согласование документов.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="prose">
        <h2>Что такое Service Desk</h2>
        <p>Service Desk — это не просто система регистрации заявок. Это управляемый процесс: каждое обращение получает статус, ответственного, срок и SLA (соглашение об уровне обслуживания). Сотрудник знает, когда его запрос будет выполнен; руководитель видит аналитику по загрузке и нарушениям сроков.</p>
        <p>Концепция пришла из ITIL — библиотеки лучших практик управления ИТ-услугами, — но давно вышла за рамки ИТ. Сегодня сервисный стол используют HR, АХО, бухгалтерия и юридические отделы: везде, где есть поток однотипных запросов.</p>

        <h2>Зачем нужен Service Desk</h2>
        <p>Без сервисного стола обращения теряются в почте и мессенджерах, сроки нарушаются, виновных не найти. Service Desk решает три задачи:</p>
        <ul>
          <li><strong>Прозрачность</strong> — статус каждой заявки виден инициатору и исполнителю в реальном времени.</li>
          <li><strong>Контроль SLA</strong> — система автоматически эскалирует просроченные задачи и фиксирует нарушения.</li>
          <li><strong>Аналитика</strong> — руководитель получает данные: сколько заявок, по каким темам, насколько быстро закрываются.</li>
        </ul>

        <h2>Service Desk в ELMA365</h2>
        <p><a href="/elma365/">ELMA365</a> позволяет построить сервисный стол на базе BPM-платформы, не покупая отдельную ITSM-систему. Обращения поступают через портал, электронную почту или мессенджер, автоматически классифицируются и маршрутизируются по бизнес-процессу. Исполнитель работает в едином интерфейсе вместе с задачами по <a href="/services/vnedrenie/">внедрению</a> и согласованию документов.</p>
        <p><strong>Пример:</strong> производственная компания внедрила Service Desk для АХО в ELMA365. 120 заявок в месяц (ремонт, закупки, уборка) теперь обрабатываются по единому процессу. Среднее время закрытия заявки сократилось с 3 дней до 6 часов — благодаря автоматической маршрутизации и SLA-уведомлениям.</p>
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <h2>Часто задаваемые вопросы</h2>
      <div class="faq">
        {faq.map(([q, a]) => (
          <div class="faq-item">
            <button class="faq-q" aria-expanded="false">{q}</button>
            <div class="faq-a">{a}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="text-align:center">
      <h2>Хотите внедрить Service Desk на ELMA365?</h2>
      <p class="muted">Расскажем, как организовать сервисный стол под ваши процессы — без лишних систем и долгого старта.</p>
      <div class="btn-row">
        <a href="/contacts/" class="btn">Обсудить проект</a>
      </div>
    </div>
  </section>

</Base>

<script>
  document.querySelectorAll(".faq-q").forEach((btn) => {
    btn.addEventListener("click", () => {
      const expanded = btn.getAttribute("aria-expanded") === "true";
      btn.setAttribute("aria-expanded", String(!expanded));
    });
  });
</script>
