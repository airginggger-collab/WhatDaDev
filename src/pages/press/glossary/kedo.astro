---
import Base from "../../../layouts/Base.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";

const title = "КЭДО — что это такое: определение и применение | WhatDaDev";
const description = "Что такое КЭДО (Кадровый электронный документооборот): определение, применение в документообороте и автоматизации процессов.";

const faq: [string, string][] = [
  ["Чем КЭДО отличается от обычного ЭДО?", "ЭДО — широкое понятие для любых электронных документов. КЭДО — его подмножество: только кадровые документы (трудовые договоры, приказы, заявления). КЭДО регулируется ст. 22.1–22.3 ТК РФ и требует квалифицированной или усиленной неквалифицированной электронной подписи."],
  ["Нужна ли электронная подпись сотруднику?", "Да. Для большинства юридически значимых документов (трудовой договор, соглашение об изменении условий) сотрудник использует УНЭП или УКЭП. Для внутренних документов — приказ об отпуске, авансовый отчёт — достаточно простой ЭП."],
  ["Обязательно ли внедрять КЭДО?", "Нет, это право, а не обязанность работодателя. Но компании с распределёнными командами и удалёнными сотрудниками экономят на печати, хранении и курьерской доставке документов."],
  ["Как КЭДО реализуется в ELMA365?", "ELMA365 содержит встроенный модуль КЭДО: маршруты согласования, интеграцию с операторами ЭП, личный кабинет сотрудника и архив документов. Настройка занимает от 2 недель в рамках экспресс-внедрения."],
];

const jsonld = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: "КЭДО: что это такое",
    description,
    author: { "@type": "Organization", name: "WhatDaDev", url: "https://whatdadev.ru" },
    publisher: { "@type": "Organization", name: "WhatDaDev", url: "https://whatdadev.ru" },
    url: "https://whatdadev.ru/press/glossary/kedo/",
    inLanguage: "ru",
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faq.map(([q, a]) => ({
      "@type": "Question",
      name: q,
      acceptedAnswer: { "@type": "Answer", text: a },
    })),
  },
];
---

<Base title={title} description={description} jsonld={jsonld}>
  <section class="hero">
    <div class="container">
      <Breadcrumbs items={[
        { name: "Главная", href: "/" },
        { name: "Пресс-центр", href: "/press/" },
        { name: "Глоссарий", href: "/press/glossary/" },
        { name: "КЭДО" },
      ]} />
      <div class="eyebrow" style="color:#a5b4fc">Глоссарий</div>
      <h1>КЭДО — что это такое</h1>
      <p class="lead">
        КЭДО (Кадровый электронный документооборот) — система обмена юридически значимыми кадровыми документами между работодателем и сотрудниками в электронном виде, без бумаги.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="prose">
        <h2>Что такое КЭДО</h2>
        <p>КЭДО — это перевод кадрового делопроизводства в цифровой формат: трудовые договоры, приказы о приёме и увольнении, заявления на отпуск, больничные, соглашения об изменении условий труда подписываются электронной подписью и хранятся в информационной системе.</p>
        <p>Правовая база — статьи 22.1–22.3 Трудового кодекса РФ (введены в 2022 году). Работодатель уведомляет сотрудников о переходе на КЭДО, получает их согласие и выбирает оператора или собственную платформу для обмена документами.</p>

        <h2>Зачем нужен КЭДО</h2>
        <p>Основные задачи, которые решает переход на электронный кадровый документооборот:</p>
        <ul>
          <li><strong>Скорость.</strong> Документ подписывается за минуты, а не дни — актуально для удалённых сотрудников и разных часовых поясов.</li>
          <li><strong>Снижение затрат.</strong> Исчезают расходы на бумагу, печать, архивные папки и курьерскую доставку.</li>
          <li><strong>Контроль и аудит.</strong> Каждое действие фиксируется: кто подписал, когда, с какой подписью. Проверка ГИТ проходит без поиска по шкафам.</li>
          <li><strong>Соответствие требованиям.</strong> Системы КЭДО обеспечивают сроки хранения по номенклатуре дел автоматически.</li>
        </ul>

        <h2>КЭДО в связке с ЭДО и ELMA365</h2>
        <p>В корпоративной автоматизации КЭДО работает как отдельный контур внутри общего ЭДО. Если компания уже автоматизировала договорной документооборот, подключение КЭДО — логичный следующий шаг: единая платформа, единый архив, единые маршруты согласования.</p>
        <p>В ELMA365 модуль КЭДО включает готовые типовые процессы: приём сотрудника, увольнение, изменение условий трудового договора. Документы уходят в личный кабинет работника, статус подписания виден в режиме реального времени. Интеграция с операторами электронной подписи (ЕСИА, КриптоПро и другими) — встроенная.</p>

        <h2>Пример внедрения</h2>
        <p>Производственная компания с 400 сотрудниками в трёх городах перешла на КЭДО за 3 недели в рамках экспресс-внедрения. Ежемесячный поток кадровых документов — около 1 200 единиц. После перехода время подписания приказа об отпуске сократилось с 3 дней до 4 часов, затраты на печать и архивирование снизились на 60%.</p>
        <p>Подробнее о подходе к внедрению — в статье <a href="/press/articles/kedo-2026/">«КЭДО в 2026 году: тренды и практика»</a>.</p>
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <h2>Частые вопросы о КЭДО</h2>
      <div class="faq">
        {faq.map(([q, a]) => (
          <div class="faq-item">
            <button class="faq-q" aria-expanded="false">{q}</button>
            <div class="faq-a">{a}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="text-align:center">
      <p class="eyebrow" style="color:#a5b4fc">Готовы внедрить КЭДО?</p>
      <h2>Разберём вашу ситуацию на бесплатной консультации</h2>
      <p class="muted" style="max-width:520px;margin:0 auto 2rem">Расскажем, как перейти на электронный кадровый документооборот в ELMA365 без остановки работы HR-отдела.</p>
      <div class="btn-row">
        <a href="/contacts/" class="btn">Получить консультацию</a>
        <a href="/services/vnedrenie/" class="btn" style="background:transparent;border:1px solid #4F46E5;color:#4F46E5">Услуги внедрения</a>
      </div>
    </div>
  </section>
</Base>

<script>
  document.querySelectorAll<HTMLButtonElement>(".faq-q").forEach((btn) => {
    btn.addEventListener("click", () => {
      const expanded = btn.getAttribute("aria-expanded") === "true";
      btn.setAttribute("aria-expanded", String(!expanded));
    });
  });
</script>
