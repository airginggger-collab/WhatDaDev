---
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { articles } from "../../data/articles.js";
const title = "Пресс-центр WhatDaDev — статьи об ELMA365 и ЭДО | WhatDaDev";
const description = "Статьи, сравнения и обзоры об ELMA365, документообороте и автоматизации процессов.";
const collectionPage = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Пресс-центр WhatDaDev",
  description,
  url: "https://whatdadev.ru/press/",
  inLanguage: "ru",
};
---
<Base title={title} description={description} jsonld={[collectionPage]}>
  <section class="hero">
    <div class="container">
      <Breadcrumbs items={[{ name: "Главная", href: "/" }, { name: "Пресс-центр" }]} />
      <h1>Пресс-центр</h1>
      <p class="lead">Статьи, сравнения и обзоры об ELMA365, документообороте и автоматизации процессов.</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="grid grid-3">
        {articles.map((a) => a.live
          ? (<a class="card" href={`/press/articles/${a.slug}/`}><span class="tag">{a.tag}</span><h3 style="margin-top:12px">{a.name}</h3><p class="muted">Читать →</p></a>)
          : (<div class="card"><span class="tag">{a.tag}</span><h3 style="margin-top:12px">{a.name}</h3><p class="muted">Скоро</p></div>))}
      </div>
    </div>
  </section>
</Base>
