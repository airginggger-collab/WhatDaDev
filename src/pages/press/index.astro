---
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { articles } from "../../data/articles.js";

const title = "Пресс-центр WhatDaDev — статьи об ELMA365 и ЭДО | WhatDaDev";
const description = "Статьи, сравнения и обзоры об ELMA365, документообороте и автоматизации процессов.";

const tagColors: Record<string, string> = {
  "Сравнение":        "#4F46E5",
  "Обзор":            "#3B82F6",
  "Гайд":             "#10B981",
  "КЭДО":             "#7C3AED",
  "ЭЦП":              "#F59E0B",
  "Процессы":         "#0D9488",
  "Импортозамещение": "#DC2626",
  "Low-code":         "#EC4899",
};

const liveArticles = articles.filter(a => a.live);
const featured = liveArticles[0];
const rest = liveArticles.slice(1);
const allTags = [...new Set(liveArticles.map(a => a.tag))];

const collectionPage = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Пресс-центр WhatDaDev",
  description,
  url: "https://whatdadev.ru/press/",
  inLanguage: "ru",
};
---
<Base title={title} description={description} jsonld={[collectionPage]}>

  <section class="hero">
    <div class="container">
      <Breadcrumbs items={[{ name: "Главная", href: "/" }, { name: "Пресс-центр" }]} />
      <h1>Пресс-центр</h1>
      <p class="lead">Статьи, сравнения и обзоры об ELMA365, документообороте и автоматизации процессов.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">

      <!-- FEATURED -->
      <a class="press-featured reveal" href={`/press/articles/${featured.slug}/`} data-tag={featured.tag}>
        <div class="press-featured-cover" style={`background:${tagColors[featured.tag] ?? '#4F46E5'}`}>
          <span class="pf-tag">{featured.tag}</span>
          <div class="pf-lines">
            <span></span><span></span><span></span>
          </div>
        </div>
        <div class="press-featured-body">
          <span class="press-tag-badge" style={`background:${tagColors[featured.tag] ?? '#4F46E5'}22;color:${tagColors[featured.tag] ?? '#4F46E5'}`}>{featured.tag}</span>
          <h2 style="margin-top:14px;margin-bottom:12px">{featured.name}</h2>
          <p class="muted">Читать статью →</p>
        </div>
      </a>

      <!-- FILTERS -->
      <div class="press-filters reveal" style="margin-top:48px;margin-bottom:28px">
        <button class="pf-btn active" data-filter="all">Все</button>
        {allTags.map(tag => (
          <button class="pf-btn" data-filter={tag} style={`--tc:${tagColors[tag] ?? '#4F46E5'}`}>{tag}</button>
        ))}
      </div>

      <!-- GRID -->
      <div class="press-grid" id="pressGrid">
        {rest.map((a, i) => (
          <a
            class="press-card reveal"
            href={`/press/articles/${a.slug}/`}
            data-tag={a.tag}
            style={`transition-delay:${(i % 3) * 60}ms`}
          >
            <div class="pc-cover" style={`background:${tagColors[a.tag] ?? '#4F46E5'}`}>
              <div class="pc-lines"><span></span><span></span></div>
            </div>
            <div class="pc-body">
              <span class="pc-tag" style={`color:${tagColors[a.tag] ?? '#4F46E5'}`}>{a.tag}</span>
              <h3>{a.name}</h3>
              <p class="muted pc-read">Читать →</p>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- GLOSSARY CTA -->
  <section class="section alt">
    <div class="container">
      <div class="eyebrow">Справочник</div>
      <h2>Глоссарий ЭДО и автоматизации</h2>
      <p class="lead" style="max-width:640px">Термины электронного документооборота, BPM-систем и автоматизации процессов — с примерами и без воды.</p>
      <div style="margin-top:24px">
        <a class="btn" href="/press/glossary/">Открыть глоссарий</a>
      </div>
    </div>
  </section>

  <!-- СОЦИАЛЬНЫЕ СЕТИ -->
  <section class="section">
    <div class="container">
      <div class="social-banner reveal">
        <div class="sb-head">
          <div class="sb-eyebrow">Блог об ELMA365</div>
          <h2 class="sb-title">Делимся каждый день</h2>
          <p class="sb-desc">Полезные скрипты, шаблоны, идеи для автоматизации и быстрые решения. Всё, что помогает работать с ELMA365 проще и эффективнее.</p>
        </div>
        <div class="sb-platforms">
          <a class="sb-card" href="https://t.me/WhatDaDev" target="_blank" rel="noopener" style="--pc:#229ED9">
            <div class="sb-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21.198 2.433a2.242 2.242 0 0 0-1.022.215l-16.5 7.5a2.25 2.25 0 0 0 .126 4.073l3.9 1.205 1.494 4.973a1.5 1.5 0 0 0 2.5.544l2.16-2.16 4.084 2.948a2.25 2.25 0 0 0 3.426-1.588l2.25-16.5a2.25 2.25 0 0 0-2.418-2.21z"/></svg>
            </div>
            <div class="sb-name">Telegram</div>
            <div class="sb-type">скрипты и гайды</div>
          </a>
          <a class="sb-card" href="#" target="_blank" rel="noopener" style="--pc:#E4405F">
            <div class="sb-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </div>
            <div class="sb-name">Instagram</div>
            <div class="sb-type">кейсы и команда</div>
          </a>
          <a class="sb-card" href="#" target="_blank" rel="noopener" style="--pc:#FF0033">
            <div class="sb-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
            </div>
            <div class="sb-name">YouTube</div>
            <div class="sb-type">видеообзоры</div>
          </a>
          <a class="sb-card" href="#" target="_blank" rel="noopener" style="--pc:#e2e8f0">
            <div class="sb-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.3 6.3 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/></svg>
            </div>
            <div class="sb-name">TikTok</div>
            <div class="sb-type">быстрые советы</div>
          </a>
          <a class="sb-card" href="#" target="_blank" rel="noopener" style="--pc:#4680C2">
            <div class="sb-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 2H3v16c0 1.1.9 2 2 2h7v2H8v2h8v-2h-4v-2h7a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2z"/><path d="M7 10h5"/><path d="M7 14h3"/></svg>
            </div>
            <div class="sb-name">ВКонтакте</div>
            <div class="sb-type">шаблоны</div>
          </a>
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ── SOCIAL BANNER ── */
  .social-banner {
    background: var(--dark-bg, #0f172a);
    border-radius: 20px;
    padding: 40px 44px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
  }
  .sb-eyebrow {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .7px;
    color: #a5b4fc;
    margin-bottom: 12px;
  }
  .sb-title {
    color: #fff;
    font-size: clamp(1.3rem, 2.2vw, 1.7rem);
    margin-bottom: 12px;
    line-height: 1.25;
  }
  .sb-desc {
    color: rgba(255,255,255,.6);
    font-size: 15px;
    line-height: 1.65;
    margin: 0;
  }
  .sb-platforms {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 10px;
  }
  .sb-card {
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.1);
    border-top: 3px solid var(--pc, #4F46E5);
    border-radius: 10px;
    padding: 14px 10px 12px;
    text-align: center;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    transition: background .2s, transform .2s;
  }
  .sb-card:hover { background: rgba(255,255,255,.11); transform: translateY(-3px); }
  .sb-icon { color: var(--pc, #a5b4fc); display: flex; align-items: center; justify-content: center; }
  .sb-name { font-size: 12px; font-weight: 600; color: #fff; }
  .sb-type { font-size: 11px; color: rgba(255,255,255,.65); }

  @media (max-width: 860px) {
    .social-banner { grid-template-columns: 1fr; padding: 28px 24px; }
    .sb-platforms { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 480px) {
    .sb-platforms { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<style>
  /* ── FEATURED ── */
  .press-featured {
    display: grid;
    grid-template-columns: 360px 1fr;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: box-shadow .25s, transform .25s;
  }
  .press-featured:hover { box-shadow: 0 8px 32px rgba(0,0,0,.1); transform: translateY(-3px); }
  .press-featured-cover {
    min-height: 260px;
    position: relative;
    display: flex;
    align-items: flex-end;
    padding: 28px;
    overflow: hidden;
  }
  .pf-tag {
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .5px;
    text-transform: uppercase;
    position: relative;
    z-index: 1;
  }
  .pf-lines {
    position: absolute;
    inset: 0;
    overflow: hidden;
    opacity: .15;
  }
  .pf-lines span {
    display: block;
    height: 1px;
    background: #fff;
    position: absolute;
    width: 140%;
    transform: rotate(-15deg);
  }
  .pf-lines span:nth-child(1) { top: 30%; left: -20%; }
  .pf-lines span:nth-child(2) { top: 55%; left: -20%; }
  .pf-lines span:nth-child(3) { top: 78%; left: -20%; }
  .press-featured-body {
    padding: 36px 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .press-featured-body h2 {
    font-size: clamp(1.2rem, 2.2vw, 1.6rem);
    line-height: 1.3;
  }

  /* ── FILTERS ── */
  .press-filters { display: flex; gap: 8px; flex-wrap: wrap; }
  .pf-btn {
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 6px 16px;
    font-size: 14px;
    cursor: pointer;
    transition: .2s;
    color: var(--text);
    font-family: inherit;
  }
  .pf-btn:hover { border-color: var(--tc, var(--accent)); color: var(--tc, var(--accent)); }
  .pf-btn.active { background: var(--tc, var(--accent)); border-color: var(--tc, var(--accent)); color: #fff; }
  .pf-btn[data-filter="all"] { --tc: var(--accent); }

  /* ── GRID ── */
  .press-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .press-card {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: box-shadow .2s, transform .2s;
  }
  .press-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,.08); transform: translateY(-3px); }
  .press-card.hidden { display: none; }
  .pc-cover {
    height: 96px;
    position: relative;
    overflow: hidden;
  }
  .pc-lines {
    position: absolute;
    inset: 0;
    opacity: .15;
  }
  .pc-lines span {
    display: block;
    height: 1px;
    background: #fff;
    position: absolute;
    width: 140%;
    transform: rotate(-15deg);
  }
  .pc-lines span:nth-child(1) { top: 35%; left: -20%; }
  .pc-lines span:nth-child(2) { top: 70%; left: -20%; }
  .pc-body {
    padding: 20px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .pc-tag { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: .4px; }
  .pc-body h3 { font-size: clamp(.9rem, 1.4vw, 1rem); line-height: 1.4; flex: 1; }
  .pc-read { font-size: 13px; margin-top: auto; }
  .press-tag-badge {
    display: inline-block;
    width: fit-content;
    font-size: 12px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: .4px;
  }

  @media (max-width: 900px) {
    .press-featured { grid-template-columns: 1fr; }
    .press-featured-cover { min-height: 160px; }
    .press-featured-body { padding: 24px; }
    .press-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .press-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.pf-btn');
  const cards = document.querySelectorAll<HTMLElement>('.press-card');

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      btns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = btn.dataset.filter;
      cards.forEach(card => {
        if (filter === 'all' || card.dataset.tag === filter) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });
</script>
