---
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { articles } from "../../data/articles.js";

const title = "Пресс-центр WhatDaDev — статьи об ELMA365 и ЭДО | WhatDaDev";
const description = "Статьи, сравнения и обзоры об ELMA365, документообороте и автоматизации процессов.";

const tagColors: Record<string, string> = {
  "Сравнение":        "#0D8148",
  "Обзор":            "#3B82F6",
  "Гайд":             "#10B981",
  "КЭДО":             "#7C3AED",
  "ЭЦП":              "#F59E0B",
  "Процессы":         "#0D9488",
  "Импортозамещение": "#DC2626",
  "Low-code":         "#EC4899",
};
const tagCovers: Record<string, string> = {
  "Сравнение":        "/covers/crm.webp",
  "Обзор":            "/covers/vnedrenie.webp",
  "Гайд":             "/covers/razrabotka.webp",
  "КЭДО":             "/covers/edo.webp",
  "ЭЦП":              "/covers/contracts.webp",
  "Процессы":         "/covers/bpm.webp",
  "Импортозамещение": "/covers/audit.webp",
  "Low-code":         "/covers/razrabotka.webp",
};

const liveArticles = articles.filter(a => a.live);
const featured = liveArticles[0];
const rest = liveArticles.slice(1);
const allTags = [...new Set(liveArticles.map(a => a.tag))];

const collectionPage = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Пресс-центр WhatDaDev",
  description,
  url: "https://whatdadev.ru/press/",
  inLanguage: "ru",
};
---
<Base title={title} description={description} jsonld={[collectionPage]}>

  <section class="hero">
    <div class="container">
      <Breadcrumbs items={[{ name: "Главная", href: "/" }, { name: "Пресс-центр" }]} />
      <h1>Пресс-центр</h1>
      <p class="lead">Статьи, сравнения и обзоры об ELMA365, документообороте и автоматизации процессов.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">

      <!-- FEATURED -->
      <a class="press-featured reveal" href={`/press/articles/${featured.slug}/`} data-tag={featured.tag}>
        <div class="press-featured-cover" style={`background-image:url(${tagCovers[featured.tag] ?? '/covers/vnedrenie.webp'})`}>
          <span class="pf-tag">{featured.tag}</span>
          <div class="pf-lines">
            <span></span><span></span><span></span>
          </div>
        </div>
        <div class="press-featured-body">
          <span class="press-tag-badge" style={`background:${tagColors[featured.tag] ?? '#0D8148'}22;color:${tagColors[featured.tag] ?? '#0D8148'}`}>{featured.tag}</span>
          <h2 style="margin-top:14px;margin-bottom:12px">{featured.name}</h2>
          <p class="muted">Читать статью →</p>
        </div>
      </a>

      <!-- FILTERS -->
      <div class="press-filters reveal" style="margin-top:48px;margin-bottom:28px">
        <button class="pf-btn active" data-filter="all">Все</button>
        {allTags.map(tag => (
          <button class="pf-btn" data-filter={tag} style={`--tc:${tagColors[tag] ?? '#0D8148'}`}>{tag}</button>
        ))}
      </div>

      <!-- GRID -->
      <div class="press-grid" id="pressGrid">
        {rest.map((a, i) => (
          <a
            class="press-card reveal"
            href={`/press/articles/${a.slug}/`}
            data-tag={a.tag}
            style={`transition-delay:${(i % 3) * 60}ms`}
          >
            <div class="pc-cover" style={`background-image:url(${tagCovers[a.tag] ?? '/covers/vnedrenie.webp'})`}>
            </div>
            <div class="pc-body">
              <span class="pc-tag" style={`color:${tagColors[a.tag] ?? '#0D8148'}`}>{a.tag}</span>
              <h3>{a.name}</h3>
              <p class="muted pc-read">Читать →</p>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- GLOSSARY CTA -->
  <section class="section alt">
    <div class="container">
      <div class="eyebrow">Справочник</div>
      <h2>Глоссарий ЭДО и автоматизации</h2>
      <p class="lead" style="max-width:640px">Термины электронного документооборота, BPM-систем и автоматизации процессов — с примерами и без воды.</p>
      <div style="margin-top:24px">
        <a class="btn" href="/press/glossary/">Открыть глоссарий</a>
      </div>
    </div>
  </section>

  <!-- СОЦИАЛЬНЫЕ СЕТИ -->
  <section class="section">
    <div class="container">
      <div class="social-banner reveal">
        <div class="sb-head">
          <div class="sb-eyebrow">Блог об ELMA365</div>
          <h2 class="sb-title">Делимся каждый день</h2>
          <p class="sb-desc">Полезные скрипты, шаблоны, идеи для автоматизации и быстрые решения. Всё, что помогает работать с ELMA365 проще и эффективнее.</p>
        </div>
        <div class="sb-platforms">
          <a class="sb-card" href="https://t.me/whatdaelma365" target="_blank" rel="noopener" style="--pc:#229ED9">
            <div class="sb-icon">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
            </div>
            <div class="sb-name">Telegram</div>
            <div class="sb-type">скрипты и гайды</div>
          </a>
          <a class="sb-card" href="https://www.instagram.com/whatdaelma365" target="_blank" rel="noopener" style="--pc:#E4405F">
            <div class="sb-icon">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
            </div>
            <div class="sb-name">Instagram</div>
            <div class="sb-type">кейсы и команда</div>
          </a>
          <a class="sb-card" href="https://www.youtube.com/@WhatDaElma365" target="_blank" rel="noopener" style="--pc:#FF0033">
            <div class="sb-icon">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/></svg>
            </div>
            <div class="sb-name">YouTube</div>
            <div class="sb-type">видеообзоры</div>
          </a>
          <a class="sb-card" href="https://www.tiktok.com/@whatdaelma365" target="_blank" rel="noopener" style="--pc:#C4C5BB">
            <div class="sb-icon">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.3 6.3 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/></svg>
            </div>
            <div class="sb-name">TikTok</div>
            <div class="sb-type">быстрые советы</div>
          </a>
          <a class="sb-card" href="https://vk.com/whatdaelma365" target="_blank" rel="noopener" style="--pc:#4680C2">
            <div class="sb-icon">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M15.684 0H8.316C1.592 0 0 1.592 0 8.316v7.368C0 22.408 1.592 24 8.316 24h7.368C22.408 24 24 22.408 24 15.684V8.316C24 1.592 22.408 0 15.684 0zm3.692 17.123h-1.744c-.66 0-.864-.525-2.05-1.727-1.033-1-1.49-.96-1.744.296v1.28c0 .377-.118.6-1.09.6-1.613 0-3.404-.985-4.666-2.82-1.9-2.663-2.42-4.65-2.42-5.052 0-.24.095-.458.458-.458h1.744c.34 0 .47.16.6.54.66 1.908 1.77 3.58 2.226 3.58.17 0 .248-.08.248-.52v-2.04c-.05-.916-.538-.995-.538-1.32 0-.16.13-.32.34-.32h2.74c.29 0 .39.15.39.5v2.75c0 .29.13.39.21.39.17 0 .31-.1.62-.41 1.032-1.16 1.77-2.95 1.77-2.95.1-.21.27-.41.61-.41h1.744c.52 0 .635.266.52.625-.23.99-2.45 3.837-2.45 3.837-.19.3-.26.44 0 .78.19.26.81.8 1.22 1.29.76.87 1.34 1.6 1.5 2.1.16.5-.09.76-.59.76z"/></svg>
            </div>
            <div class="sb-name">ВКонтакте</div>
            <div class="sb-type">шаблоны</div>
          </a>
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ── SOCIAL BANNER ── */
  .social-banner {
    background: var(--dark-bg, #191D1B);
    border-radius: 20px;
    padding: 40px 44px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
  }
  .sb-eyebrow {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .7px;
    color: #9AD1AF;
    margin-bottom: 12px;
  }
  .sb-title {
    color: #fff;
    font-size: clamp(1.3rem, 2.2vw, 1.7rem);
    margin-bottom: 12px;
    line-height: 1.25;
  }
  .sb-desc {
    color: rgba(255,255,255,.6);
    font-size: 15px;
    line-height: 1.65;
    margin: 0;
  }
  .sb-platforms {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 10px;
  }
  .sb-card {
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 12px;
    padding: 16px 10px 14px;
    text-align: center;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    transition: background .2s, transform .2s;
  }
  .sb-card:hover { background: rgba(255,255,255,.11); transform: translateY(-3px); }
  .sb-icon {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: rgba(255,255,255,.1);
    color: var(--pc, #9AD1AF);
    display: flex; align-items: center; justify-content: center;
  }
  .sb-name { font-size: 12px; font-weight: 600; color: #fff; }
  .sb-type { font-size: 11px; color: rgba(255,255,255,.65); }

  @media (max-width: 860px) {
    .social-banner { grid-template-columns: 1fr; padding: 28px 24px; }
    .sb-platforms { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 480px) {
    .sb-platforms { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<style>
  /* ── FEATURED ── */
  .press-featured {
    display: grid;
    grid-template-columns: 360px 1fr;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: box-shadow .25s, transform .25s;
  }
  .press-featured:hover { box-shadow: 0 8px 32px rgba(0,0,0,.1); transform: translateY(-3px); }
  .press-featured-cover {
    min-height: 260px;
    position: relative;
    display: flex;
    align-items: flex-end;
    padding: 28px;
    overflow: hidden;
    background-size: cover;
    background-position: center top;
  }
  .press-featured-cover::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,.55) 0%, rgba(0,0,0,.0) 50%);
    z-index: 0;
  }
  .pf-tag {
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .5px;
    text-transform: uppercase;
    position: relative;
    z-index: 1;
  }
  .press-featured-body {
    padding: 36px 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .press-featured-body h2 {
    font-size: clamp(1.2rem, 2.2vw, 1.6rem);
    line-height: 1.3;
  }

  /* ── FILTERS ── */
  .press-filters { display: flex; gap: 8px; flex-wrap: wrap; }
  .pf-btn {
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 6px 16px;
    font-size: 14px;
    cursor: pointer;
    transition: .2s;
    color: var(--text);
    font-family: inherit;
  }
  .pf-btn:hover { border-color: var(--tc, var(--accent)); color: var(--tc, var(--accent)); }
  .pf-btn.active { background: var(--tc, var(--accent)); border-color: var(--tc, var(--accent)); color: #fff; }
  .pf-btn[data-filter="all"] { --tc: var(--accent); }

  /* ── GRID ── */
  .press-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .press-card {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: box-shadow .2s, transform .2s;
  }
  .press-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,.08); transform: translateY(-3px); }
  .press-card.hidden { display: none; }
  .pc-cover {
    height: 104px;
    position: relative;
    overflow: hidden;
    background-size: cover;
    background-position: center top;
  }
  .pc-cover::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,.35) 0%, rgba(0,0,0,.0) 60%);
  }
  .pc-lines span:nth-child(1) { top: 35%; left: -20%; }
  .pc-lines span:nth-child(2) { top: 70%; left: -20%; }
  .pc-body {
    padding: 20px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .pc-tag { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: .4px; }
  .pc-body h3 { font-size: clamp(.9rem, 1.4vw, 1rem); line-height: 1.4; flex: 1; }
  .pc-read { font-size: 13px; margin-top: auto; }
  .press-tag-badge {
    display: inline-block;
    width: fit-content;
    font-size: 12px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: .4px;
  }

  @media (max-width: 900px) {
    .press-featured { grid-template-columns: 1fr; }
    .press-featured-cover { min-height: 160px; }
    .press-featured-body { padding: 24px; }
    .press-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .press-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.pf-btn');
  const cards = document.querySelectorAll<HTMLElement>('.press-card');

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      btns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = btn.dataset.filter;
      cards.forEach(card => {
        if (filter === 'all' || card.dataset.tag === filter) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });
</script>
