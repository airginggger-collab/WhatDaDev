---
import { getCollection, render } from "astro:content";
import Base from "../../../layouts/Base.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import { articleLd } from "../../../lib/schema.ts";

export async function getStaticPaths() {
  const entries = await getCollection("articles", ({ data }) => !data.draft);
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);

const jsonld = articleLd(d, `https://whatdadev.ru/press/articles/${entry.id}/`);
---
<Base title={d.title} description={d.description} jsonld={jsonld}>
  <section class="hero">
    <div class="container">
      <Breadcrumbs items={d.crumbs} />
      {d.eyebrow && <div class="eyebrow eyebrow-light">{d.eyebrow}</div>}
      <h1>{d.h1}</h1>
      {d.lead && <p class="lead">{d.lead}</p>}
    </div>
  </section>
  <Content />
</Base>
