---
import Base from "../../../layouts/Base.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
const title = "Коробочный ЭДО или облачный: что выбрать | WhatDaDev";
const description = "Коробочный ЭДО для внутреннего согласования vs облачные операторы для обмена с контрагентами. В чём разница.";
const article = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "Коробочный ЭДО или облачный: что выбрать для внутреннего документооборота",
  description,
  author: { "@type": "Organization", name: "WhatDaDev", url: "https://whatdadev.ru" },
  publisher: { "@type": "Organization", name: "WhatDaDev", url: "https://whatdadev.ru" },
  url: "https://whatdadev.ru/press/articles/korobochnyy-edo-vs-oblachnyy/",
  inLanguage: "ru",
};
---
<Base title={title} description={description} jsonld={[article]}>
  <section class="hero">
    <div class="container">
      <Breadcrumbs items={[{ name: "Главная", href: "/" }, { name: "Коробочный или облачный ЭДО" }]} />
      <div class="eyebrow" style="color:#8FBBE0">Сравнение</div>
      <h1>Коробочный ЭДО или облачный: что выбрать для внутреннего документооборота</h1>
      <p class="lead">Это решения для разных задач. Облачные операторы — про обмен с контрагентами; коробочный ЭДО — про внутреннее согласование на своём сервере.</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="grid grid-2">
        <div class="card"><h3>Коробочный (Coordo / ELMA365)</h3><p>Внутреннее согласование договоров, ОРД, корреспонденции на вашем сервере. Разовая цена, данные у вас, маршруты без кода.</p></div>
        <div class="card"><h3>Облачный оператор (Диадок, СБИС)</h3><p>Обмен юридически значимыми документами с контрагентами через оператора. Данные у оператора, абонентская плата.</p></div>
      </div>
    </div>
  </section>
  <section class="section alt">
    <div class="container">
      <h2>Можно вместе</h2>
      <p class="lead">Коробочный ЭДО для внутренних процессов + интеграция с Диадок/СБИС для обмена с контрагентами (в дорожной карте Coordo). Одно не заменяет другое.</p>
      <div class="btn-row"><a class="btn" href="/products/express/">Смотреть продукт</a></div>
    </div>
  </section>
  <section class="hero">
    <div class="container center">
      <h2 style="color:#fff">Подберём вариант под вашу задачу</h2>
      <div class="btn-row" style="justify-content:center"><a class="btn" href="/contacts/">Записаться на демо</a></div>
    </div>
  </section>
</Base>
