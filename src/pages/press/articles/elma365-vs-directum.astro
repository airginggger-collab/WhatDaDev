<style>
  .faq { display: flex; flex-direction: column; gap: 2px; }
  .faq-item { border: 1px solid var(--border); border-radius: var(--radius-sm); overflow: hidden; }
  .faq-q {
    width: 100%; text-align: left; background: var(--surface); border: none; padding: 18px 20px;
    font-size: 16px; font-weight: 500; cursor: pointer; color: var(--text);
    display: flex; justify-content: space-between; align-items: center; gap: 12px;
  }
  .faq-q::after { content: "+"; font-size: 20px; color: var(--accent); flex-shrink: 0; transition: transform var(--transition-fast); }
  .faq-q[aria-expanded="true"]::after { transform: rotate(45deg); }
  .faq-a { display: none; padding: 0 20px 18px; color: var(--muted); line-height: 1.7; background: var(--surface); }
  .faq-q[aria-expanded="true"] + .faq-a { display: block; }
  .muted { color: var(--muted); }
</style>

<script>
  document.querySelectorAll('.faq-q').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
    });
  });
</script>
