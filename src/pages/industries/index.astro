---
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { industries } from "../../data/industries.js";
const title = "ELMA365 по отраслям: производство, ритейл, девелопмент, логистика, финансы | WhatDaDev";
const description = "Документооборот и автоматизация процессов на ELMA365 под вашу отрасль. РФ и СНГ.";

const industryColors: Record<string, string> = {
  "proizvodstvo": "#4F46E5",
  "ritejl":       "#3B82F6",
  "development":  "#F59E0B",
  "logistika":    "#0D9488",
  "finance":      "#7C3AED",
};
const industryCovers: Record<string, string> = {
  "proizvodstvo": "/covers/vnedrenie.png",
  "ritejl":       "/covers/crm.webp",
  "development":  "/covers/razrabotka.webp",
  "logistika":    "/covers/bpm.webp",
  "finance":      "/covers/contracts.webp",
};

const getLabel = (h1: string) => h1.split(":")[0].replace("ELMA365 для ", "").replace("ELMA365 для", "");
const capitalize = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);

const featured = industries[0];
const rest = industries.slice(1);
---
<Base title={title} description={description}>

  <section class="hero">
    <div class="container">
      <Breadcrumbs items={[{ name: "Главная", href: "/" }, { name: "Отрасли" }]} />
      <h1>ELMA365 под вашу отрасль</h1>
      <p class="lead">Документооборот и процессы под специфику отрасли — на готовых контурах и под ключ.</p>
      <div class="btn-row"><a class="btn" href="/contacts/">Записаться на демо</a></div>
    </div>
  </section>

  <section class="section">
    <div class="container">

      <!-- FEATURED -->
      <a class="ind-featured reveal" href={`/industries/${featured.slug}/`}>
        <div class="ind-cover" style={`background-image:url(${industryCovers[featured.slug] ?? ''})`}>
          <span class="ind-cover-label">{capitalize(getLabel(featured.h1))}</span>
        </div>
        <div class="ind-body">
          <span class="ind-badge" style={`background:${industryColors[featured.slug] ?? '#4F46E5'}22;color:${industryColors[featured.slug] ?? '#4F46E5'}`}>{capitalize(getLabel(featured.h1))}</span>
          <h2 style="margin-top:14px;margin-bottom:12px">{featured.h1.split(":")[0]}</h2>
          <p style="color:var(--muted);font-size:15px;line-height:1.65">{featured.lead}</p>
          <p class="muted" style="margin-top:16px;font-size:14px">Подробнее →</p>
        </div>
      </a>

      <!-- GRID -->
      <div class="ind-grid" style="margin-top:32px">
        {rest.map((x, i) => {
          const label = capitalize(getLabel(x.h1));
          const color = industryColors[x.slug] ?? '#4F46E5';
          return (
            <a class="ind-card reveal" href={`/industries/${x.slug}/`} style={`transition-delay:${(i%2)*60}ms`}>
              <div class="ind-card-cover" style={`background-image:url(${industryCovers[x.slug] ?? ''})`}>
              </div>
              <div class="ind-card-body">
                <span class="ind-card-tag" style={`color:${color}`}>{label}</span>
                <h3>{label}</h3>
                <p class="muted">{x.lead}</p>
                <p class="muted" style="font-size:13px;margin-top:auto">Подробнее →</p>
              </div>
            </a>
          );
        })}
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="hero" style="min-height:auto">
    <div class="container center" style="padding-top:72px;padding-bottom:72px;width:100%">
      <h2 style="color:#fff;max-width:560px;margin:0 auto 16px">Автоматизируем процессы под вашу отрасль</h2>
      <p style="color:var(--dark-muted);margin-bottom:28px;max-width:440px;margin-left:auto;margin-right:auto">Покажем как ELMA365 решает задачи именно вашего бизнеса.</p>
      <div class="btn-row" style="justify-content:center">
        <a class="btn" href="/contacts/">Записаться на демо</a>
      </div>
    </div>
  </section>

</Base>

<style>
  /* FEATURED */
  .ind-featured {
    display: grid;
    grid-template-columns: 320px 1fr;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: box-shadow .25s, transform .25s;
  }
  .ind-featured:hover { box-shadow: 0 8px 32px rgba(0,0,0,.1); transform: translateY(-3px); }
  .ind-cover {
    min-height: 240px;
    position: relative;
    display: flex;
    align-items: flex-end;
    padding: 28px;
    overflow: hidden;
    background-size: cover;
    background-position: center top;
  }
  .ind-cover::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,.55) 0%, rgba(0,0,0,.0) 50%);
    z-index: 0;
  }
  .ind-cover-label {
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .5px;
    text-transform: uppercase;
    position: relative;
    z-index: 1;
  }
  .ind-body {
    padding: 36px 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .ind-body h2 { font-size: clamp(1.1rem, 2vw, 1.5rem); line-height: 1.3; }
  .ind-badge {
    display: inline-block;
    width: fit-content;
    font-size: 12px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: .4px;
  }

  /* GRID */
  .ind-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  .ind-card {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: box-shadow .2s, transform .2s;
  }
  .ind-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,.08); transform: translateY(-3px); }
  .ind-card-cover {
    height: 104px;
    position: relative;
    overflow: hidden;
    background-size: cover;
    background-position: center top;
  }
  .ind-card-cover::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,.35) 0%, rgba(0,0,0,.0) 60%);
  }
  .ind-card-body {
    padding: 20px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .ind-card-tag { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .4px; }
  .ind-card-body h3 { font-size: clamp(.95rem, 1.4vw, 1.05rem); line-height: 1.4; }
  .ind-card-body p { font-size: 14px; line-height: 1.6; }

  @media (max-width: 860px) {
    .ind-featured { grid-template-columns: 1fr; }
    .ind-cover { min-height: 140px; }
    .ind-body { padding: 24px; }
  }
  @media (max-width: 560px) {
    .ind-grid { grid-template-columns: 1fr; }
  }
</style>
