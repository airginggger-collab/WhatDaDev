---
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { items as industries } from "../../data/industries.json";
import CtaHero from "../../components/CtaHero.astro";
const title = "ELMA365 по отраслям: производство, ритейл, девелопмент, логистика, финансы | WhatDaDev";
const description = "Документооборот и автоматизация процессов на ELMA365 под вашу отрасль. РФ и КЗ.";

const industryColors: Record<string, string> = {
  "proizvodstvo": "#1F5B99",
  "ritejl":       "#3B82F6",
  "development":  "#F59E0B",
  "logistika":    "#0D9488",
  "finance":      "#7C3AED",
};
const industryCovers: Record<string, string> = {
  "proizvodstvo": "/covers/vnedrenie.webp",
  "ritejl":       "/covers/crm.webp",
  "development":  "/covers/razrabotka.webp",
  "logistika":    "/covers/bpm.webp",
  "finance":      "/covers/contracts.webp",
};

const getLabel = (h1: string) => h1.split(":")[0].replace("ELMA365 для ", "").replace("ELMA365 для", "");
const capitalize = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);

const featured = industries[0];
const rest = industries.slice(1);
---
<Base title={title} description={description}>

  <section class="hero">
    <div class="container">
      <Breadcrumbs items={[{ name: "Главная", href: "/" }, { name: "Отрасли" }]} />
      <h1>ELMA365 под вашу отрасль</h1>
      <p class="lead">Документооборот и процессы под специфику отрасли: на готовых контурах и под ключ.</p>
      <div class="btn-row"><a class="btn" href="/contacts/">Записаться на демо</a></div>
    </div>
  </section>

  <section class="section">
    <div class="container cover-ind">

      <!-- FEATURED -->
      <a class="cover-featured reveal" href={`/industries/${featured.slug}/`}>
        <div class="cover-featured-cover" style={`background-image:url(${industryCovers[featured.slug] ?? ''})`}>
          <span class="cover-featured-label">{capitalize(getLabel(featured.h1))}</span>
        </div>
        <div class="cover-featured-body">
          <span class="cover-badge" style={`background:${industryColors[featured.slug] ?? '#1F5B99'}22;color:${industryColors[featured.slug] ?? '#1F5B99'}`}>{capitalize(getLabel(featured.h1))}</span>
          <h2 style="margin-top:14px;margin-bottom:12px">{featured.h1.split(":")[0]}</h2>
          <p style="color:var(--muted);font-size:15px;line-height:1.65">{featured.lead}</p>
          <p class="muted" style="margin-top:16px;font-size:14px">Подробнее →</p>
        </div>
      </a>

      <!-- GRID -->
      <div class="cover-grid" style="margin-top:32px">
        {rest.map((x, i) => {
          const label = capitalize(getLabel(x.h1));
          const color = industryColors[x.slug] ?? '#1F5B99';
          return (
            <a class="cover-card reveal" href={`/industries/${x.slug}/`} style={`transition-delay:${(i%2)*60}ms`}>
              <div class="cover-card-cover" style={`background-image:url(${industryCovers[x.slug] ?? ''})`}>
              </div>
              <div class="cover-card-body">
                <span class="cover-card-tag" style={`color:${color}`}>{label}</span>
                <h3>{label}</h3>
                <p class="muted">{x.lead}</p>
                <p class="muted" style="font-size:13px;margin-top:auto">Подробнее →</p>
              </div>
            </a>
          );
        })}
      </div>

    </div>
  </section>

  <CtaHero wide title="Автоматизируем процессы под вашу отрасль" lead="Покажем как ELMA365 решает задачи именно вашего бизнеса." button="Записаться на демо" />

</Base>
