---
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { items as industries } from "../../data/industries.json";
import CtaHero from "../../components/CtaHero.astro";
import { serviceLd, SITE } from "../../lib/schema.ts";
export function getStaticPaths() {
  return industries.map((x) => ({ params: { slug: x.slug }, props: { x } }));
}
const { x } = Astro.props;
// Service был тонким: без description, а provider дублировал Organization инлайном.
const jsonld = [
  serviceLd({
    name: x.h1,
    description: x.desc,
    url: `${SITE}/industries/${x.slug}/`,
    serviceType: "Внедрение ELMA365",
  }),
];
---
<Base title={x.title} description={x.desc} jsonld={jsonld}>
  <section class="hero">
    <div class="container">
      <Breadcrumbs items={[{ name: "Главная", href: "/" }, { name: "Отрасли", href: "/industries/" }, { name: x.h1 }]} />
      <div class="eyebrow eyebrow-light">Отрасль</div>
      <h1>{x.h1}</h1>
      <p class="lead">{x.lead}</p>
      <div class="btn-row"><a class="btn" href="/contacts/">Записаться на демо</a></div>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <h2>Боли отрасли</h2>
      <div class="grid grid-2" style="margin-top:24px">
        {x.pains.map((p) => (<div class="card"><p>{p}</p></div>))}
      </div>
    </div>
  </section>
  <section class="section alt">
    <div class="container">
      <h2>Что автоматизируем</h2>
      <div class="grid grid-2" style="margin-top:24px">
        {x.items.map((it) => (<div class="card"><p>{it}</p></div>))}
      </div>
    </div>
  </section>
  <CtaHero title="Покажем на ваших процессах" button="Записаться на демо" />
</Base>
