---
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { faqLd } from "../../lib/schema.ts";
import CtaHero from "../../components/CtaHero.astro";

const title = "Внедрение ELMA365 в Казахстане: автоматизация процессов on-prem | WhatDaDev";
const description = "Внедряем ELMA365 в Казахстане: сквозные процессы, ЭДО, CRM и ServiceDesk на своих серверах. On-prem, выкупные лицензии, локальный партнёр по внедрению. Обсудить проект.";

// Боли KZ-бизнеса (каркас с лендинга ELMA365, переформулировано под средний бизнес РК)
const pains = [
  { t: "Зоопарк систем и интеграций", d: "Разрозненные приложения приходится постоянно связывать между собой. Данные расходятся, поддержка дорожает." },
  { t: "Рост стоимости подписок и привязка к облаку", d: "Иностранные SaaS дорожают, а данные и процессы оказываются за периметром компании." },
  { t: "Сложность масштабирования", d: "Каждая доработка требует подрядчика. Своя команда не может развивать систему без вендора." },
  { t: "Безопасность при внедрении ИИ", d: "Нет архитектуры, которая позволяет использовать ИИ-модели без риска утечки корпоративных данных." },
];

// Аргументы (суверенность / экономика / локальный партнёр)
const args = [
  { t: "Процессы on-prem", d: "ELMA365 разворачивается на ваших серверах. Данные остаются внутри контура компании, без зависимости от иностранных облаков." },
  { t: "Выкупные лицензии", d: "Лицензия покупается, а не арендуется. Предсказуемый TCO вместо растущей ежемесячной подписки." },
  { t: "Свой центр компетенций", d: "Low-code платформа позволяет вашей команде развивать систему самостоятельно, без постоянной привязки к подрядчику." },
  { t: "Локальный партнёр по внедрению", d: "{{Статус партнёрства ELMA365 в РК: уточнить}}. Внедряем по собственному ежедневному опыту работы на ELMA365." },
];

// Локализация РК: ВСЁ требует подтверждения (Фаза 0), поэтому заглушки
const local = [
  { t: "ЭЦП и eGov", d: "{{Интеграция с ЭЦП / NCA РК и eGov: подтвердить, что поддерживаем}}" },
  { t: "Законодательство РК", d: "{{Соответствие требованиям законодательства РК: уточнить перечень}}" },
  { t: "Тенге и учёт", d: "{{Валюта тенге, локальные форматы и интеграция с 1С: подтвердить}}" },
  { t: "Отрасли РК", d: "Банки и финтех, логистика и торговля, производство. {{Приоритетные отрасли для КЗ: согласовать}}" },
];

const faqKz = [
  ["Работаете ли вы с компаниями из Казахстана?", "Да. Внедряем ELMA365 для компаний в РК и РФ. {{Формат работы и договора для КЗ: уточнить в Фазе 0}}."],
  ["Можно ли развернуть ELMA365 на своих серверах в Казахстане?", "Да, ELMA365 поддерживает on-premises развёртывание без функциональных отличий от облака. Процессы и данные остаются внутри вашего контура."],
  ["Кто уже использует ELMA365 в Казахстане?", "{{Референсы ELMA365 в КЗ (например, Air Astana, Bereke Bank): согласовать формулировку и право упоминания}}."],
  ["Чем ELMA365 отличается от иностранных систем?", "Разворачивается локально, лицензия выкупная, а не по подписке, платформа low-code позволяет развивать решение своей командой без привязки к вендору."],
];

// Заглушки {{...}} (Фаза 0) НЕ размечаем как факты: разметка отзывов/референсов,
// которых нет как подтверждённого контента, нарушает правило проекта. Фильтруем до faqLd.
// Видимые заглушки остаются контент-задачей владельца (Фаза 0).
const jsonld = [faqLd(faqKz.filter(([, a]) => !a.includes("{{")))];
---
<Base title={title} description={description} jsonld={jsonld}>

  <section class="hero">
    <div class="container">
      <Breadcrumbs items={[{ name: "Главная", href: "/" }, { name: "Казахстан" }]} />
      <div class="eyebrow">ELMA365 в Казахстане</div>
      <h1>Автоматизация бизнеса в Казахстане на ELMA365</h1>
      <p class="lead">Выстраиваем сквозные процессы на своих серверах: ЭДО, CRM, ServiceDesk и закупки на Enterprise low-code платформе. Без привязки к иностранным облакам.</p>
      <div class="btn-row">
        <a class="btn" href="/contacts/">Обсудить проект</a>
        <a class="btn-secondary" href="/products/express/">Готовый ЭДО из коробки</a>
      </div>
      <div class="proof"><span><b>4+</b> года на ELMA365</span><span>on-prem развёртывание</span><span>РФ и КЗ</span></div>
    </div>
  </section>

  <!-- БОЛИ -->
  <section class="section">
    <div class="container">
      <div class="eyebrow reveal">Что мешает расти</div>
      <h2 class="reveal">Знакомые сложности казахстанского бизнеса</h2>
      <div class="grid grid-2" style="margin-top:32px;align-items:start">
        {pains.map((p) => (
          <div class="card reveal">
            <h3>{p.t}</h3>
            <p class="muted">{p.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- СУВЕРЕННОСТЬ / АРГУМЕНТЫ -->
  <section class="section alt">
    <div class="container">
      <div class="eyebrow reveal">Почему on-prem</div>
      <h2 class="reveal">Контроль над процессами и данными остаётся у вас</h2>
      <div class="grid grid-2" style="margin-top:32px;align-items:start">
        {args.map((a) => (
          <div class="card reveal">
            <h3>{a.t}</h3>
            <p class="muted">{a.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ЛОКАЛИЗАЦИЯ РК -->
  <section class="section">
    <div class="container">
      <div class="eyebrow reveal">Локализация РК</div>
      <h2 class="reveal">Под требования казахстанского рынка</h2>
      <p class="muted reveal" style="max-width:640px">Ниже блок фактов по локализации. Формулировки заполняются после подтверждения заказчиком, чтобы не публиковать неточные заявления.</p>
      <div class="grid grid-2" style="margin-top:32px;align-items:start">
        {local.map((l) => (
          <div class="card reveal">
            <h3>{l.t}</h3>
            <p class="muted">{l.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaHero wide title="Покажем ELMA365 на вашем процессе" lead="Разберём задачу и предложим путь: готовый продукт из коробки или внедрение под ключ." button="Записаться на демо" leadMaxWidth={460} />

  <!-- FAQ -->
  <section class="section alt">
    <div class="container" style="max-width:760px">
      <div class="eyebrow reveal">FAQ</div>
      <h2 class="reveal">Вопросы про ELMA365 в Казахстане</h2>
      <div class="faq reveal" style="margin-top:32px">
        {faqKz.map(([q, a]) => (
          <div class="faq-item">
            <button class="faq-q" aria-expanded="false">{q}</button>
            <div class="faq-a"><p>{a}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

</Base>
