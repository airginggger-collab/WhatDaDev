---
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
const title = "Услуги по ELMA365: внедрение, разработка, поддержка | WhatDaDev";
const description = "Полный цикл работы с ELMA365: внедрение под ключ, разработка и интеграции, аутстаффинг, аудит, консалтинг, обучение. РФ и СНГ.";
const faqServices = [
  ["С чего начать внедрение ELMA365?", "Начинаем с бесплатного демо — разбираем ваши процессы, показываем что можно автоматизировать. Занимает 30–45 минут онлайн."],
  ["Вы работаете с малым бизнесом?", "Да. Экспресс внедрение специально создано для компаний от 10 сотрудников. Для крупных проектов — полное внедрение под ключ."],
  ["Что входит в услугу разработки?", "Проектирование бизнес-процессов, разработка модулей ELMA365, интеграции с 1С/CRM/ERP, тестирование и обучение пользователей."],
  ["Можно ли мигрировать с другой системы?", "Да, помогаем с миграцией с Битрикс24, 1С:Документооборот и других систем. Разрабатываем план без потери данных."],
];
const jsonld = [
  { "@context": "https://schema.org", "@type": "FAQPage", mainEntity: faqServices.map(([q, a]) => ({ "@type": "Question", name: q, acceptedAnswer: { "@type": "Answer", text: a } })) },
];
const services = [
  ["Внедрение", "CRM, ЭДО, ServiceDesk, закупки, маркетинг, проекты, КЭДО и другие процессы.", "/services/vnedrenie/"],
  ["Разработка", "Модули, интеграции (1С, API), доработки под ваши задачи.", "/services/razrabotka/"],
  ["Аутстаффинг", "Наши специалисты усиливают вашу команду.", null],
  ["Аудит", "Проверка и оптимизация внедрённых решений.", null],
  ["Консалтинг", "Цифровая трансформация и оптимизация процессов.", null],
  ["Обучение", "Чтобы команда работала в системе самостоятельно.", null],
  ["Покупка лицензий", "Подбор и поставка лицензий ELMA365.", null],
];
---
<Base title={title} description={description} jsonld={jsonld}>
  <section class="hero">
    <div class="container">
      <Breadcrumbs items={[{ name: "Главная", href: "/" }, { name: "Услуги" }]} />
      <h1>Услуги по ELMA365: от внедрения до поддержки</h1>
      <p class="lead">Внедряем, дорабатываем, обучаем и сопровождаем ELMA365. Под РФ и СНГ.</p>
      <div class="btn-row"><a class="btn" href="/contacts/">Обсудить проект</a></div>
      <div class="proof"><span><b>12</b> внедрений</span><span>сертифицированные эксперты</span></div>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <h2>Что мы делаем</h2>
      <div class="grid grid-3" style="margin-top:24px">
        {services.map(([t, d, href]) => href
          ? (<a class="card" href={href}><h3>{t}</h3><p>{d}</p></a>)
          : (<div class="card"><h3>{t}</h3><p>{d}</p></div>))}
      </div>
    </div>
  </section>
  <section class="section">
    <div class="container" style="max-width:760px">
      <div class="eyebrow reveal">FAQ</div>
      <h2 class="reveal">Частые вопросы об услугах</h2>
      <div class="faq reveal" style="margin-top:32px">
        {faqServices.map(([q, a]) => (
          <div class="faq-item">
            <button class="faq-q" aria-expanded="false">{q}</button>
            <div class="faq-a">{a}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
  <section class="hero">
    <div class="container center">
      <h2 style="color:#fff">Обсудим вашу задачу</h2>
      <p class="lead" style="margin:0 auto">Расскажите о процессах — предложим решение и оценку.</p>
      <div class="btn-row" style="justify-content:center"><a class="btn" href="/contacts/">Обсудить проект</a></div>
    </div>
  </section>
</Base>
