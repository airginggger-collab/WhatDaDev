---
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
const title = "Услуги по ELMA365: от внедрения до поддержки | WhatDaDev";
const description = "Полный цикл работы с ELMA365: внедрение под ключ, разработка и интеграции, поддержка и обучение, консалтинг, аудит, аутстаффинг. РФ и КЗ.";
const faqServices = [
  ["С чего начать внедрение ELMA365?", "Начинаем с бесплатного демо — разбираем ваши процессы, показываем что можно автоматизировать. Занимает 30–45 минут онлайн."],
  ["Вы работаете с малым бизнесом?", "Да. Экспресс внедрение специально создано для компаний от 10 сотрудников. Для крупных проектов — полное внедрение под ключ."],
  ["Что входит в услугу разработки?", "Проектирование бизнес-процессов, разработка модулей ELMA365, интеграции с 1С/CRM/ERP, тестирование и обучение пользователей."],
  ["Можно ли мигрировать с другой системы?", "Да, помогаем с миграцией с Битрикс24, 1С:Документооборот и других систем. Разрабатываем план без потери данных."],
];
const jsonld = [
  { "@context": "https://schema.org", "@type": "FAQPage", mainEntity: faqServices.map(([q, a]) => ({ "@type": "Question", name: q, acceptedAnswer: { "@type": "Answer", text: a } })) },
];

const serviceColors: Record<string, string> = {
  "Внедрение":            "#1F5B99",
  "Разработка":           "#3B82F6",
  "Поддержка и обучение": "#10B981",
  "Консалтинг":           "#7C3AED",
  "Аудит":                "#F59E0B",
  "Аутстаффинг":          "#0D9488",
};

const services = [
  { name: "Внедрение",            desc: "Быстрое и качественное внедрение ELMA365 под ключ: CRM, ЭДО, ServiceDesk, закупки, проекты, КЭДО.", href: "/services/vnedrenie/",  cover: "/covers/vnedrenie.webp"  },
  { name: "Разработка",           desc: "Кастомные приложения и интеграции для ELMA365: 1С, API, доработки под ваши задачи.",                 href: "/services/razrabotka/", cover: "/covers/razrabotka.webp" },
  { name: "Поддержка и обучение", desc: "Техническая поддержка, сопровождение и обучение сотрудников.",                                       href: null,                    cover: "/covers/edo.webp"        },
  { name: "Консалтинг",           desc: "Консалтинг по автоматизации и цифровой трансформации.",                                              href: null,                    cover: "/covers/bpm.webp"        },
  { name: "Аудит",                desc: "Аудит уже внедрённых решений: проверка и оптимизация.",                                              href: null,                    cover: "/covers/audit.webp"      },
  { name: "Аутстаффинг",          desc: "Аутстаффинг специалистов для работы с ELMA365 — усиливаем вашу команду.",                            href: null,                    cover: "/covers/crm.webp"        },
];

const featured = services[0];
const rest = services.slice(1);
---
<Base title={title} description={description} jsonld={jsonld}>

  <section class="hero">
    <div class="container">
      <Breadcrumbs items={[{ name: "Главная", href: "/" }, { name: "Услуги" }]} />
      <h1>Услуги по ELMA365: от внедрения до поддержки</h1>
      <p class="lead">Внедряем, дорабатываем, обучаем и сопровождаем ELMA365. Под РФ и КЗ.</p>
      <div class="btn-row"><a class="btn" href="/contacts/">Обсудить проект</a></div>
      <div class="proof"><span><b>4+</b> года на ELMA365</span><span>сертифицированные эксперты</span><span>РФ и КЗ</span></div>
    </div>
  </section>

  <section class="section">
    <div class="container">

      <!-- FEATURED -->
      <a class="srv-featured reveal" href={featured.href!}>
        <div class="srv-cover" style={`background-image:url(${featured.cover})`}>
          <span class="srv-cover-label">{featured.name}</span>
        </div>
        <div class="srv-body">
          <span class="srv-badge" style={`background:${serviceColors[featured.name]}22;color:${serviceColors[featured.name]}`}>{featured.name}</span>
          <h2 style="margin-top:14px;margin-bottom:12px">Внедрение ELMA365 под ключ</h2>
          <p style="color:var(--muted);font-size:15px;line-height:1.65">{featured.desc} От анализа процессов до запуска и поддержки — берём на себя весь цикл.</p>
          <p class="muted" style="margin-top:16px;font-size:14px">Подробнее →</p>
        </div>
      </a>

      <!-- GRID -->
      <div class="srv-grid" style="margin-top:32px">
        {rest.map((s, i) => s.href
          ? (
            <a class="srv-card reveal" href={s.href} style={`transition-delay:${(i%3)*60}ms`}>
              <div class="srv-card-cover" style={`background-image:url(${s.cover})`}>
              </div>
              <div class="srv-card-body">
                <span class="srv-card-tag" style={`color:${serviceColors[s.name]}`}>{s.name}</span>
                <h3>{s.name}</h3>
                <p class="muted">{s.desc}</p>
                <p class="muted" style="font-size:13px;margin-top:auto">Подробнее →</p>
              </div>
            </a>
          ) : (
            <div class="srv-card reveal" style={`transition-delay:${(i%3)*60}ms`}>
              <div class="srv-card-cover" style={`background-image:url(${s.cover})`}>
              </div>
              <div class="srv-card-body">
                <span class="srv-card-tag" style={`color:${serviceColors[s.name]}`}>{s.name}</span>
                <h3>{s.name}</h3>
                <p class="muted">{s.desc}</p>
                <p class="muted" style="font-size:13px;margin-top:auto;color:var(--accent)">Уточнить →</p>
              </div>
            </div>
          )
        )}
      </div>

    </div>
  </section>

  <!-- FAQ -->
  <section class="section alt">
    <div class="container" style="max-width:760px">
      <div class="eyebrow reveal">FAQ</div>
      <h2 class="reveal">Частые вопросы об услугах</h2>
      <div class="faq reveal" style="margin-top:32px">
        {faqServices.map(([q, a]) => (
          <div class="faq-item">
            <button class="faq-q" aria-expanded="false">{q}</button>
            <div class="faq-a"><p>{a}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="hero" style="min-height:auto">
    <div class="container center" style="padding-top:72px;padding-bottom:72px;width:100%">
      <h2 style="color:#fff;max-width:560px;margin:0 auto 16px">Обсудим вашу задачу</h2>
      <p style="color:var(--dark-muted);margin-bottom:28px;max-width:440px;margin-left:auto;margin-right:auto">Расскажите о процессах — предложим решение и оценку.</p>
      <div class="btn-row" style="justify-content:center">
        <a class="btn" href="/contacts/">Обсудить проект</a>
      </div>
    </div>
  </section>

</Base>

<style>
  /* FEATURED */
  .srv-featured {
    display: grid;
    grid-template-columns: 320px 1fr;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: box-shadow .25s, transform .25s;
  }
  .srv-featured:hover { box-shadow: 0 8px 32px rgba(0,0,0,.1); transform: translateY(-3px); }
  .srv-cover {
    min-height: 240px;
    position: relative;
    display: flex;
    align-items: flex-end;
    padding: 28px;
    overflow: hidden;
    background-size: cover;
    background-position: center top;
  }
  .srv-cover::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,.55) 0%, rgba(0,0,0,.0) 50%);
    z-index: 0;
  }
  .srv-cover-label {
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .5px;
    text-transform: uppercase;
    position: relative;
    z-index: 1;
  }
  .srv-body {
    padding: 36px 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .srv-body h2 { font-size: clamp(1.1rem, 2vw, 1.5rem); line-height: 1.3; }
  .srv-badge {
    display: inline-block;
    width: fit-content;
    font-size: 12px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: .4px;
  }

  /* GRID */
  .srv-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .srv-card {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: box-shadow .2s, transform .2s;
    cursor: pointer;
  }
  .srv-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,.08); transform: translateY(-3px); }
  .srv-card-cover {
    height: 104px;
    position: relative;
    overflow: hidden;
    background-size: cover;
    background-position: center top;
  }
  .srv-card-cover::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,.35) 0%, rgba(0,0,0,.0) 60%);
  }
  .srv-card-body {
    padding: 20px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .srv-card-tag { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .4px; }
  .srv-card-body h3 { font-size: clamp(.9rem, 1.3vw, 1rem); line-height: 1.4; }
  .srv-card-body p { font-size: 14px; line-height: 1.55; }

  @media (max-width: 860px) {
    .srv-featured { grid-template-columns: 1fr; }
    .srv-cover { min-height: 140px; }
    .srv-body { padding: 24px; }
    .srv-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .srv-grid { grid-template-columns: 1fr; }
  }
</style>
