---
import Base from "../../../layouts/Base.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import { items as directions } from "../../../data/directions.json";
const title = "Внедрение ELMA365 под ключ — быстро и надёжно | WhatDaDev";
const description = "Внедряем ELMA365 под ключ: CRM, ЭДО, ServiceDesk, закупки, проекты, КЭДО. Аналитика, настройка, поддержка. Работаем с релиза платформы.";
const steps = [
  { title: "Выявление потребностей", desc: "Интервью с ключевыми пользователями и руководителями. Анализируем текущие процессы, фиксируем боли и определяем приоритеты автоматизации." },
  { title: "Заключение договора", desc: "Фиксируем объём, сроки и стоимость. Подписываем NDA при необходимости — конфиденциальность ваших данных гарантирована." },
  { title: "Детальная аналитика", desc: "Описываем бизнес-процессы «как есть» и «как будет». Согласовываем схемы маршрутов, ролевую модель и интеграции." },
  { title: "Проектная документация", desc: "Техническое задание, согласованное с заказчиком. Документация — основа для разработки и приёмки. Без неё не начинаем." },
  { title: "Разработка и тестирование", desc: "Настраиваем ELMA365 строго по ТЗ. Приёмочное тестирование проводим совместно — вы проверяете каждый сценарий до запуска." },
  { title: "Промышленная эксплуатация", desc: "Обучаем пользователей, переносим данные, запускаем в рабочую среду и сопровождаем систему: техническая поддержка и развитие решения." },
];
const jsonld = [{ "@context": "https://schema.org", "@type": "Service", name: "Внедрение ELMA365 под ключ", serviceType: "Внедрение ELMA365", url: "https://whatdadev.ru/services/vnedrenie", areaServed: ["RU", "KZ"], provider: { "@type": "Organization", name: "WhatDaDev", url: "https://whatdadev.ru" } }];
---
<Base title={title} description={description} jsonld={jsonld}>
  <section class="hero">
    <div class="container">
      <Breadcrumbs items={[{ name: "Главная", href: "/" }, { name: "Услуги", href: "/services/" }, { name: "Внедрение" }]} />
      <h1>Внедрение ELMA365 под ключ</h1>
      <p class="lead">От анализа процессов до запуска и поддержки. Настраиваем ELMA365 под ваши задачи — CRM, документооборот, сервис, закупки, проекты, КЭДО.</p>
      <div class="btn-row"><a class="btn" href="/contacts/">Обсудить проект</a></div>
      <div class="proof"><span><b>4+</b> года на ELMA365</span><span>сертифицированные эксперты</span><span>РФ и КЗ</span></div>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <h2>Что автоматизируем на ELMA365</h2>
      <div class="grid grid-3" style="margin-top:24px">
        {directions.map((d) => (<a class="card" href={`/services/vnedrenie/${d.slug}/`}><h3>{d.h1.replace(/^Внедрение |^Автоматизация |^Управление /, "")}</h3><p>{d.lead}</p></a>))}
      </div>
    </div>
  </section>
  <section class="section alt">
    <div class="container">
      <div class="eyebrow reveal">Процесс внедрения</div>
      <h2 class="reveal">Как мы работаем</h2>
      <p class="lead reveal">Шесть этапов от первого звонка до рабочей системы. Никаких сюрпризов — каждый шаг зафиксирован в договоре.</p>
      <div class="timeline" style="margin-top:40px">
        {steps.map((s, i) => (
          <div class="tl-item reveal" style={`transition-delay:${i * 60}ms`}>
            <div class="tl-left">
              <div class="tl-num">{i + 1}</div>
              {i < steps.length - 1 && <div class="tl-line"></div>}
            </div>
            <div class="tl-body">
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

<style>
  .timeline { display: flex; flex-direction: column; gap: 0; }
  .tl-item { display: grid; grid-template-columns: 56px 1fr; gap: 20px; }
  .tl-left { display: flex; flex-direction: column; align-items: center; }
  .tl-num {
    width: 44px; height: 44px; border-radius: 50%;
    background: var(--accent); color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px; font-weight: 700; flex-shrink: 0;
    box-shadow: 0 0 0 4px rgba(31,91,153,.15);
  }
  .tl-line { flex: 1; width: 2px; background: var(--border); margin: 6px 0; min-height: 32px; }
  .tl-body { padding-bottom: 32px; }
  .tl-body h3 { font-size: 1.05rem; margin-bottom: 6px; }
  .tl-body p { color: var(--muted); font-size: 15px; line-height: 1.6; margin: 0; }
</style>
  <section class="hero">
    <div class="container center">
      <h2 style="color:#fff">Обсудим вашу задачу</h2>
      <div class="btn-row" style="justify-content:center"><a class="btn" href="/contacts/">Обсудить проект</a></div>
    </div>
  </section>
</Base>
