---
import Base from "../../../layouts/Base.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import { items as directions } from "../../../data/directions.json";
export function getStaticPaths() {
  return directions.map((d) => ({ params: { slug: d.slug }, props: { d } }));
}
const { d } = Astro.props;
const jsonld = [{ "@context": "https://schema.org", "@type": "Service", name: d.h1, url: `https://whatdadev.ru/services/vnedrenie/${d.slug}/`, areaServed: ["RU", "KZ"], provider: { "@type": "Organization", name: "WhatDaDev", url: "https://whatdadev.ru" } }];
---
<Base title={d.title} description={d.desc} jsonld={jsonld}>
  <section class="hero">
    <div class="container">
      <Breadcrumbs items={[{ name: "Главная", href: "/" }, { name: "Услуги", href: "/services/" }, { name: "Внедрение", href: "/services/vnedrenie/" }, { name: d.h1 }]} />
      <div class="eyebrow eyebrow-light">Услуги · Внедрение</div>
      <h1>{d.h1}</h1>
      <p class="lead">{d.lead}</p>
      <div class="btn-row"><a class="btn" href="/contacts/">Обсудить проект</a></div>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <h2>Что автоматизируем</h2>
      <div class="grid grid-3" style="margin-top:24px">
        {d.items.map((it) => (<div class="card"><p>{it}</p></div>))}
      </div>
      {d.note && (<p class="muted" style="margin-top:18px">{d.note} <a href={d.noteHref} style="color:var(--accent)">Подробнее →</a></p>)}
    </div>
  </section>
  <section class="hero">
    <div class="container center">
      <h2 style="color:#fff">Обсудим вашу задачу</h2>
      <div class="btn-row center"><a class="btn" href="/contacts/">Обсудить проект</a></div>
    </div>
  </section>
</Base>
