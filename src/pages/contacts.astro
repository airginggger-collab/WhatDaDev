---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import contacts from "../data/contacts.json";
import { ORG_REF, SITE } from "../lib/schema.ts";
const title = "Контакты WhatDaDev: внедрение ELMA365 | РФ и КЗ";
const description = "Свяжитесь с WhatDaDev: Telegram, WhatsApp, email. Записаться на демо или обсудить внедрение ELMA365.";

// ContactPage со списком реальных точек связи. Значения из contacts.json.
const contactPage = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "Контакты WhatDaDev",
  description,
  url: `${SITE}/contacts/`,
  inLanguage: "ru",
  about: ORG_REF,
  mainEntity: {
    ...ORG_REF,
    "@type": "Organization",
    contactPoint: [
      {
        "@type": "ContactPoint", contactType: "sales",
        telephone: contacts.phone, email: contacts.email,
        areaServed: ["RU", "KZ"], availableLanguage: "ru",
      },
      {
        "@type": "ContactPoint", contactType: "technical support",
        email: contacts.support_email,
        areaServed: ["RU", "KZ"], availableLanguage: "ru",
      },
      {
        "@type": "ContactPoint", contactType: "HR",
        email: contacts.career_email,
        availableLanguage: "ru",
      },
    ],
  },
};
---
<Base title={title} description={description} jsonld={[contactPage]}>
  <section class="hero">
    <div class="container">
      <Breadcrumbs items={[{ name: "Главная", href: "/" }, { name: "Контакты" }]} />
      <h1>Контакты</h1>
      <p class="lead">Запишитесь на демо или обсудите внедрение ELMA365. Ответим в Telegram, WhatsApp или на почту.</p>
    </div>
  </section>
  <section class="section">
    <div class="container grid grid-2">
      <div class="card">
        <h3>Записаться на демо</h3>
        <form class="form" id="leadForm" style="margin-top:12px">
          <p class="form-note" style="margin-bottom:2px">Поля со звёздочкой <span class="req">*</span> обязательны</p>
          <label><span>Имя <span class="req" aria-hidden="true">*</span></span><input name="name" required autocomplete="name" placeholder="Иван Петров" /></label>
          <label><span>Телефон <span class="req" aria-hidden="true">*</span></span><input name="phone" type="tel" required autocomplete="tel" placeholder="+7 900 000-00-00" /></label>
          <label>Email<input name="email" type="email" autocomplete="email" placeholder="ivan@company.ru" /></label>
          <label>Компания<input name="company" autocomplete="organization" placeholder="ООО «Ромашка»" /></label>
          <label>Сообщение<textarea name="message" placeholder="Хочу автоматизировать согласование договоров, 50 сотрудников"></textarea></label>
          <label class="row"><input type="checkbox" required style="width:auto" /> <span>Согласен на обработку персональных данных <span class="req" aria-hidden="true">*</span></span></label>
          <button class="btn" type="submit">Записаться на демо</button>
          <p class="form-note">Ответим в течение рабочего дня. Без спама, только по вашему запросу.</p>
          <p class="form-note" id="formMsg">Онлайн-приём заявок подключается к CRM. Быстрее всего написать нам напрямую в Telegram или WhatsApp.</p>
        </form>
      </div>
      <div class="card alt">
        <h3>Связаться напрямую</h3>
        <p><a href={`https://t.me/${contacts.telegram}`}>Telegram @{contacts.telegram}</a></p>
        <p><a href={`https://wa.me/${contacts.phone_href.replace('+','')}`}>WhatsApp {contacts.phone}</a></p>
        <p>Тел: <a href={`tel:${contacts.phone_href}`}>{contacts.phone}</a></p>
        <p>Email: <a href={`mailto:${contacts.email}`}>{contacts.email}</a></p>
        <p class="muted" style="font-size:13px">Тех. поддержка: <a href={`mailto:${contacts.support_email}`}>{contacts.support_email}</a></p>
        <p class="muted" style="font-size:13px">Карьера: резюме на <a href={`mailto:${contacts.career_email}`}>{contacts.career_email}</a>. Работаем удалённо, из любой точки мира.</p>

        <h3 style="margin-top:22px">Социальные сети</h3>
        <p><a href={`https://t.me/${contacts.telegram_channel}`} target="_blank" rel="noopener">Telegram-канал @{contacts.telegram_channel}</a>: приёмы ELMA365</p>
        <p><a href={contacts.instagram} target="_blank" rel="noopener">Instagram</a> · <a href={contacts.youtube} target="_blank" rel="noopener">YouTube</a> · <a href={contacts.vk} target="_blank" rel="noopener">VK</a> · <a href={contacts.tiktok} target="_blank" rel="noopener">TikTok</a></p>

        <h3 style="margin-top:22px">Реквизиты</h3>
        <p class="muted" style="font-size:13px">РФ: {contacts.requisites_ru}</p>
        <p class="muted" style="font-size:13px">КЗ: {contacts.requisites_kz}</p>
      </div>
    </div>
  </section>
  <script define:vars={{ tgUser: contacts.telegram, waPhone: contacts.phone_href.replace('+','') }}>
    const f = document.getElementById('leadForm');
    f && f.addEventListener('submit', (e) => {
      e.preventDefault();
      const m = document.getElementById('formMsg');
      const data = new FormData(f);
      const text = 'Заявка на демо: ' + (data.get('name') || '') + ', ' + (data.get('phone') || '') + (data.get('company') ? ', ' + data.get('company') : '') + (data.get('message') ? ': ' + data.get('message') : '');
      m.innerHTML = 'Приём заявок через сайт ещё подключается. Чтобы мы точно не потеряли ваш запрос, <a href="https://t.me/' + tgUser + '" target="_blank" rel="noopener" style="text-decoration:underline">отправьте его в Telegram</a> или <a href="https://wa.me/' + waPhone + '?text=' + encodeURIComponent(text) + '" target="_blank" rel="noopener" style="text-decoration:underline">в WhatsApp одним нажатием</a>.';
      m.classList.add('form-ok');
    });
  </script>
</Base>
