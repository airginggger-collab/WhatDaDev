---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
const title = "Контакты WhatDaDev — внедрение ELMA365 | РФ и КЗ";
const description = "Свяжитесь с WhatDaDev: Telegram, WhatsApp, email. Записаться на демо или обсудить внедрение ELMA365.";
---
<Base title={title} description={description}>
  <section class="hero">
    <div class="container">
      <Breadcrumbs items={[{ name: "Главная", href: "/" }, { name: "Контакты" }]} />
      <h1>Контакты</h1>
      <p class="lead">Запишитесь на демо или обсудите внедрение ELMA365. Ответим в Telegram, WhatsApp или на почту.</p>
    </div>
  </section>
  <section class="section">
    <div class="container grid grid-2">
      <div class="card">
        <h3>Записаться на демо</h3>
        <form class="form" id="leadForm" style="margin-top:12px">
          <p class="form-note" style="margin-bottom:2px">Поля со звёздочкой <span class="req">*</span> — обязательны</p>
          <label><span>Имя <span class="req" aria-hidden="true">*</span></span><input name="name" required autocomplete="name" placeholder="Иван Петров" /></label>
          <label><span>Телефон <span class="req" aria-hidden="true">*</span></span><input name="phone" type="tel" required autocomplete="tel" placeholder="+7 900 000-00-00" /></label>
          <label>Email<input name="email" type="email" autocomplete="email" placeholder="ivan@company.ru" /></label>
          <label>Компания<input name="company" autocomplete="organization" placeholder="ООО «Ромашка»" /></label>
          <label>Сообщение<textarea name="message" placeholder="Хочу автоматизировать согласование договоров, 50 сотрудников"></textarea></label>
          <label class="row"><input type="checkbox" required style="width:auto" /> <span>Согласен на обработку персональных данных <span class="req" aria-hidden="true">*</span></span></label>
          <button class="btn" type="submit">Записаться на демо</button>
          <p class="form-note">Ответим в течение рабочего дня. Без спама — только по вашему запросу.</p>
          <p class="form-note" id="formMsg">Онлайн-приём заявок подключается к CRM. Быстрее всего — написать нам напрямую в Telegram или WhatsApp.</p>
        </form>
      </div>
      <div class="card alt">
        <h3>Связаться напрямую</h3>
        <p><a href="https://t.me/WhatDaDev">Telegram @WhatDaDev</a></p>
        <p><a href="https://wa.me/79804715772">WhatsApp +7 980 471-57-72</a></p>
        <p>Тел: <a href="tel:+79804715772">+7 980 471-57-72</a></p>
        <p>Email: <a href="mailto:sales@whatdadev.ru">sales@whatdadev.ru</a></p>
        <p class="muted" style="font-size:13px">Тех. поддержка: <a href="mailto:support@whatdadev.ru">support@whatdadev.ru</a></p>
        <p class="muted" style="font-size:13px">Карьера: резюме на <a href="mailto:iperushev@whatdadev.ru">iperushev@whatdadev.ru</a>. Работаем удалённо — из любой точки мира.</p>

        <h3 style="margin-top:22px">Социальные сети</h3>
        <p><a href="https://t.me/whatdaelma365" target="_blank" rel="noopener">Telegram-канал @whatdaelma365</a> — приёмы ELMA365</p>
        <p><a href="https://www.instagram.com/whatdaelma365" target="_blank" rel="noopener">Instagram</a> · <a href="https://www.youtube.com/@WhatDaElma365" target="_blank" rel="noopener">YouTube</a> · <a href="https://vk.com/whatdaelma365" target="_blank" rel="noopener">VK</a> · <a href="https://www.tiktok.com/@whatdaelma365" target="_blank" rel="noopener">TikTok</a></p>

        <h3 style="margin-top:22px">Реквизиты</h3>
        <p class="muted" style="font-size:13px">РФ: ИП Перушев Игорь Петрович<br/>ИНН 772864679384 · ОГРНИП 323774600482278</p>
        <p class="muted" style="font-size:13px">КЗ: ИП «Бауырсак»<br/>ИИН 910316450932</p>
      </div>
    </div>
  </section>
  <script>
    const f = document.getElementById('leadForm');
    f && f.addEventListener('submit', (e) => {
      e.preventDefault();
      const m = document.getElementById('formMsg');
      const data = new FormData(f);
      const text = 'Заявка на демо: ' + (data.get('name') || '') + ', ' + (data.get('phone') || '') + (data.get('company') ? ', ' + data.get('company') : '') + (data.get('message') ? ' — ' + data.get('message') : '');
      m.innerHTML = 'Приём заявок через сайт ещё подключается. Чтобы мы точно не потеряли ваш запрос — <a href="https://t.me/WhatDaDev" target="_blank" rel="noopener" style="text-decoration:underline">отправьте его в Telegram</a> или <a href="https://wa.me/79804715772?text=' + encodeURIComponent(text) + '" target="_blank" rel="noopener" style="text-decoration:underline">в WhatsApp одним нажатием</a>.';
      m.classList.add('form-ok');
    });
  </script>
</Base>
