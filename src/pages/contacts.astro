---
import Base from "../layouts/Base.astro";
const title = "Контакты WhatDaDev — внедрение ELMA365 | РФ и КЗ";
const description = "Свяжитесь с WhatDaDev: Telegram, WhatsApp, email. Записаться на демо или обсудить внедрение ELMA365.";
---
<Base title={title} description={description}>
  <section class="hero">
    <div class="container">
      <h1>Контакты</h1>
      <p class="lead">Запишитесь на демо или обсудите внедрение ELMA365. Ответим в Telegram, WhatsApp или на почту.</p>
    </div>
  </section>
  <section class="section">
    <div class="container grid grid-2">
      <div class="card">
        <h3>Связаться</h3>
        <p>Telegram: <a href="https://t.me/WhatDaDev">@WhatDaDev</a></p>
        <p>WhatsApp / тел: +7 980 471-57-72</p>
        <p>Email: <a href="mailto:sales@whatdadev.ru">sales@whatdadev.ru</a></p>
        <div class="btn-row"><a class="btn" href="https://t.me/WhatDaDev">Написать в Telegram</a></div>
      </div>
      <div class="card alt">
        <h3>Реквизиты</h3>
        <p class="muted">РФ: ИП Перушев Игорь Петрович<br/>КЗ: ИП «Бауырсак»</p>
        <p class="muted" style="font-size:13px">Прототип — реквизиты и форма заявки в ELMA CRM подключаются на этапе разработки.</p>
      </div>
    </div>
  </section>
</Base>
