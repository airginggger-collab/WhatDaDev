{
  "$meta": {
    "status": "draft / provisional",
    "version": "v0.16",
    "note": "Вектор: тёмный hero -> светлый контент (ADR-0002), акцент НЕ красный (ADR-0003). accent и fontFamily — ПРЕДВАРИТЕЛЬНЫЕ, финал после Apple-референсов (Фаза 0). Значения готовы к маппингу в Tailwind/CSS-переменные."
  },
  "color": {
    "light": {
      "bg": "#F8FAFC",
      "surface": "#FFFFFF",
      "surfaceAlt": "#F1F5F9",
      "text": "#0F172A",
      "textMuted": "#475569",
      "textSubtle": "#64748B",
      "border": "#E2E8F0"
    },
    "dark": {
      "bg": "#0B1220",
      "surface": "#111827",
      "surfaceAlt": "#1A2233",
      "text": "#F8FAFC",
      "textMuted": "#94A3B8",
      "textSubtle": "#64748B",
      "border": "#1F2937",
      "heroGlow": "rgba(79,70,229,0.25)"
    },
    "accent": {
      "$note": "Кандидат A — electric-indigo (по умолчанию). Кандидат B — teal (см. accentAlt).",
      "50": "#EEF0FE",
      "100": "#E0E3FD",
      "400": "#6366F1",
      "500": "#4F46E5",
      "600": "#4338CA",
      "700": "#3730A3",
      "contrastText": "#FFFFFF"
    },
    "accentAlt": {
      "$note": "Альтернатива — teal/мятный, если Apple-референсы уведут в спокойную сторону.",
      "400": "#2DD4BF",
      "500": "#0EA5A4",
      "600": "#0F766E"
    },
    "semantic": {
      "success": "#16A34A",
      "warning": "#D97706",
      "danger": "#DC2626",
      "$note": "danger=красный только для ошибок/валидации, НЕ как бренд-акцент."
    }
  },
  "typography": {
    "fontFamily": {
      "sans": "Inter, system-ui, sans-serif",
      "$candidates": ["Inter", "Manrope", "Geist", "Onest"],
      "$note": "Характерный гротеск; финал — после референсов. Кириллица обязательна."
    },
    "weight": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 },
    "scalePx": {
      "display": 64,
      "h1": 48,
      "h2": 36,
      "h3": 24,
      "h4": 20,
      "body": 16,
      "small": 14,
      "caption": 13
    },
    "scaleMobilePx": { "display": 40, "h1": 32, "h2": 26, "h3": 20, "h4": 18, "body": 16 },
    "lineHeight": { "tight": 1.1, "snug": 1.3, "normal": 1.5, "relaxed": 1.65 }
  },
  "radius": { "sm": 8, "md": 12, "lg": 16, "xl": 24, "full": 9999 },
  "spacingPx": [4, 8, 12, 16, 24, 32, 48, 64, 96, 128],
  "shadow": {
    "sm": "0 1px 2px rgba(15,23,42,0.06)",
    "md": "0 4px 16px rgba(15,23,42,0.08)",
    "lg": "0 12px 40px rgba(15,23,42,0.12)",
    "$note": "Мягкие тени, без неона/glow в светлой теме."
  },
  "layout": { "containerMaxPx": 1200, "gutterPx": 24, "sectionPaddingY": 96 },
  "motion": {
    "ease": "cubic-bezier(0.16, 1, 0.3, 1)",
    "durationMs": { "fast": 150, "base": 220, "slow": 320 },
    "$note": "Уважать prefers-reduced-motion. Анимации не блокируют LCP (ADR-0004)."
  }
}
